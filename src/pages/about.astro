---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import Breadcrumbs from '../components/ui/Breadcrumbs.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import DynamicIcon from '../components/ui/DynamicIcon.astro';
import SinglePinMap from '../components/maps/SinglePinMap.astro';
import { getEntry } from 'astro:content';

const aboutData = await getEntry('site', 'about');
const milestones = aboutData?.data.milestones || [];
const values = aboutData?.data.values || [];
---

<Layout 
  title="Our Story | About Sea Skiathos"
  description="Born and raised on the waters of Skiathos. Learn about our history, our values, and why we are the island's most trusted boat rental and tour company."
>
  <HeroSection
    title="Born in the<br/>Aegean"
    subtitle="The story of a local family-run business dedicated to showing you the true soul of Skiathos by sea."
    gradient="dark"
    size="medium"
    showScrollHint={false}
    backgroundImage="/images/stock/s2tock images.webp"
  />

  <Breadcrumbs />

  <section class="section">
    <div class="container grid grid-cols-1 lg:grid-cols-[1.2fr_1fr] gap-16 items-center">
      <div class="reveal">
        <SectionHeading 
          label="The Beginning" 
          title="From a Single Kaiki to a Modern Fleet" 
          align="left"
        />
        <div class="text-lg leading-relaxed text-muted-foreground space-y-6 mb-12">
          <p>
            Our story began over 30 years ago. Growing up in Skiathos Town, the sea wasn't just a view—it was our playground, our pantry, and eventually, our passion. What started with one small wooden boat helping friends reach Lalaria has grown into the island's most comprehensive maritime service.
          </p>
          <p>
            We are not just another middleman. In fact, we actively eliminate middlemen by connecting you directly to the operators' booking systems, ensuring a seamless experience. Because we have direct access to each business's live schedule, we guarantee the services and pricing we offer. You don't just book a trip with us—we take complete responsibility for your booking and support you through every single step of your experience.
          </p>
          <p>
            If you want to mix and match any of our services—a self-drive rental in the morning, a private sunset cruise in the evening, or airport transfers—we make the entire process seamless.
          </p>
        </div>
        
        <div class="flex flex-col gap-8 mt-12">
          {milestones.map((m: any) => (
            <div class="flex gap-6 group">
              <span class="text-2xl font-bold text-foreground opacity-20 group-hover:opacity-100 transition-opacity min-w-[80px]">{m.year}</span>
              <div class="flex flex-col gap-1">
                <h3 class="text-base font-bold text-foreground m-0">{m.title}</h3>
                <p class="text-sm text-muted-foreground m-0 leading-relaxed">{m.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="reveal">
        <div class="aspect-[4/5] relative rounded-sm overflow-hidden placeholder-dark">
          <div class="absolute bottom-8 -left-4 bg-foreground p-8 rounded-sm text-background flex flex-col shadow-2xl">
            <strong class="text-4xl font-extrabold leading-none">30+</strong>
            <span class="text-[0.65rem] font-bold uppercase tracking-widest mt-2">Years of History</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-black text-white">
    <div class="container">
      <SectionHeading 
        label="What We Stand For" 
        title="Our Core Values" 
        align="center"
      />
      
      <div class="grid-cards mt-16 text-center">
        {values.map((v: any) => (
          <div class="reveal">
            <div class="card group bg-white/5 border-white/10 p-12 text-center">
              <div class="card-content">
                <span class="inline-flex mb-6 opacity-40">
                  <DynamicIcon name={v.icon} size={48} strokeWidth={1} />
                </span>
                <h3 class="text-white text-xl font-bold mb-4">{v.title}</h3>
                <p class="text-white/60 text-sm leading-relaxed">{v.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--muted">
    <div class="container">
      <SectionHeading
        label="Finding Us"
        title="Where We're Based"
        description="Visit our main hub at the Old Port of Skiathos — the heart of the island's maritime life."
      />
      <div class="map-container reveal">
        <SinglePinMap
          lat={39.1618}
          lng={23.4895}
          label="Skiathos Old Port"
          sub="Main Hub & Headquarters"
          href="/locations/skiathos-old-port/"
          height="400px"
          zoom={15}
        />
      </div>
    </div>
  </section>

</Layout>

<style>
  .section { padding: 5rem 0; }
  .section--muted { background: var(--muted); }
  .map-container {
    border-radius: var(--radius-2xl);
    overflow: hidden;
    border: 1px solid var(--border);
  }
</style>
