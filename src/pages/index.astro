---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import ServiceCard from '../components/cards/ServiceCard.astro';
import BoatCard from '../components/cards/BoatCard.astro';
import ReviewSlider from '../components/sections/ReviewSlider.astro';
import BlogCard from '../components/cards/BlogCard.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
import LocationHighlights from '../components/sections/LocationHighlights.astro';
import WhyChooseUs from '../components/sections/WhyChooseUs.astro';
import FeaturedTours from '../components/sections/FeaturedTours.astro';
import { getCollection, getEntry } from 'astro:content';
import { 
  getFeaturedFleet, 
  getLatestPosts, 
  getSortedServices, 
  getSortedTours, 
  getSortedLocations, 
  getSiteSettings 
} from '../lib/collections';

// Load content via centralized utilities
const featuredBoats = await getFeaturedFleet();
const featuredPosts = await getLatestPosts();
const pillars = await getSortedServices();
const allTours = await getSortedTours();
const locationHighlights = await getSortedLocations();
const site = await getSiteSettings();

const allTestimonials = await getCollection('testimonials');
const testimonials = allTestimonials
  .map((entry) => entry.data)
  .sort((a, b) => (b.featured === true ? 1 : 0) - (a.featured === true ? 1 : 0))
  .slice(0, 10);

// Use the first 3 tours as featured on home
const featuredTours = allTours.slice(0, 3);
---

<Layout
  title={site?.seo?.defaultTitle}
  description={site?.seo?.defaultDescription}
>

  <!-- ① HERO ────────────────────────────────── -->
  <HeroSection
    title={site?.hero?.title || "Explore Skiathos by Sea"}
    subtitle={site?.hero?.subtitle || "Premium boat rental and sea experiences in the Aegean."}
    ctaText="Rent a Boat"
    ctaHref="/boat-rental/"
    ctaSecondText="Browse Tours"
    ctaSecondHref="/private-boat-tours/"
    gradient="moody"
    size="full"
    backgroundImage="/images/stock/s1tock images.webp"
  />

  <!-- ② SERVICE PILLARS ──────────────────────── -->
  <section class="section" id="services">
    <div class="container">
      <SectionHeading
        label="Everything by Sea"
        title="What We Offer"
        description="One company, four ways to experience the Aegean from Skiathos."
      />
      <div class="grid-cards">
        {pillars.map((p) => (
          <ServiceCard
            icon={p.data.icon}
            title={p.data.title}
            description={p.data.description}
            href={p.data.href}
            price={p.data.price}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ③ FEATURED FLEET ───────────────────────── -->
  <section class="section section-muted" id="fleet">
    <div class="container">
      <SectionHeading
        label="Our Fleet"
        title="Choose Your Boat"
        description="From no-license motorboats to high-power RIBs and luxury yachts — the largest fleet on the island, all bookable direct."
      />
      <div class="grid-cards">
        {featuredBoats.map((boat) => (
          <BoatCard
            name={boat.data.name}
            type={boat.data.type}
            priceFrom={boat.data.priceFrom}
            priceHalfDay={boat.data.priceHalfDay}
            priceFullDay={boat.data.priceFullDay}
            slug={boat.id}
            image={boat.data.image}
            imagePlaceholder={boat.data.imagePlaceholder}
            features={boat.data.features}
            specs={[
              { label: 'Length', value: boat.data.length },
              { label: 'Capacity', value: `${boat.data.capacity} pers.` },
              { label: 'Engine', value: `${boat.data.horsepower} HP` },
            ]}
          />
        ))}
      </div>
      <div class="flex justify-center mt-10">
        <a href="/fleet/" class="btn btn-primary">View Full Fleet</a>
      </div>
    </div>
  </section>

  <!-- ④ POPULAR TOURS ────────────────────────── -->
  <FeaturedTours tours={featuredTours} />

  <!-- ⑤ WHY CHOOSE US ────────────────────────── -->
  <WhyChooseUs items={site?.whyUs ?? []} />

  <!-- ⑥ REVIEWS ─────────────────────────── -->
  <ReviewSlider reviews={testimonials} />

  <!-- ⑦ LOCATION HIGHLIGHTS ──────────────────── -->
  <LocationHighlights locations={locationHighlights} />

  <!-- ⑧ BLOG HIGHLIGHTS ──────────────────────── -->
  <section class="section" id="blog">
    <div class="container">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
        <SectionHeading
          label="Captain's Log"
          title="Latest from the Blog"
          description="Tips, itineraries, and insider guides to help you make the most of Skiathos by sea."
          align="left"
        />
        <a href="/blog/" class="btn btn-secondary mb-4 md:mb-0">Explore All Articles</a>
      </div>
      <div class="grid-cards">
        {featuredPosts.map((post) => (
          <BlogCard
            title={post.data.title}
            excerpt={post.data.description}
            slug={post.id}
            pubDate={post.data.pubDate.toISOString()}
            readTime={String(post.data.readTime)}
            category={post.data.category}
            image={post.data.image}
            imagePlaceholder={post.data.imagePlaceholder}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ⑨ CTA BANNER ──────────────────────────── -->
  <CtaBanner
    title="Book Your Skiathos Sea Adventure Today"
    subtitle="The island's largest fleet. Book direct — no platform markups. Free quote within 2 hours."
    buttonText="Book Now"
    buttonHref="/contact/"
    secondButtonText="View All Services"
    secondButtonHref="/boat-rental/"
    variant="dark"
    backgroundImage="/images/stock/s10tock images.webp"
  />

</Layout>
