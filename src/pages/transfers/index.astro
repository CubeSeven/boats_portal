---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import ServiceCard from '../../components/cards/ServiceCard.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import ReviewSlider from '../../components/sections/ReviewSlider.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import FaqAccordion from '../../components/sections/FaqAccordion.astro';
import { getCollection } from 'astro:content';
import { getSiteSettings } from '../../lib/collections';

const site = await getSiteSettings();

const allActivities = await getCollection('activities');
const transferRoutes = allActivities
  .filter(a => a.data.category === 'transfers')
  .sort((a, b) => a.data.order - b.data.order);

const allFaqs = await getCollection('faqs');
const transferFaqs = allFaqs
  .filter(f => f.data.category === 'transfers')
  .map(f => f.data);

const allTestimonials = await getCollection('testimonials');
const testimonials = allTestimonials
  .map((entry) => entry.data)
  .sort((a, b) => (b.featured === true ? 1 : 0) - (a.featured === true ? 1 : 0))
  .slice(0, 10);
---

<Layout 
  title="Transfer Skiathos | 24/7 Private Sea Transfers"
  description="The fastest private sea transfers in the Sporades. 24/7 transfer service from Skiathos to Volos, Skopelos, Pelion, and Airport. Fast, reliable, and private."
>
  <HeroSection
    title="24/7 Transfer<br/>Skiathos"
    subtitle="Your private bridge across the Aegean. Fast, reliable, and available whenever you need it. Skip the ferry schedules and arrive on your own time."
    ctaText="Book a Transfer"
    ctaHref="/contact/"
    ctaSecondText="View Routes"
    ctaSecondHref="#routes"
    gradient="ocean"
    size="medium"
    showScrollHint={false}
    backgroundImage="/images/stock/boat_moored_near_rocky_cliff_beach.webp"
  />

  <Breadcrumbs />

  <!-- Intro -->
  <section class="section">
    <div class="container">
      <SectionHeading
        label="Private Transfers"
        title="We Run on Your Schedule"
        description="No waiting for ferry arrivals. No restricted timetables. Our transfer service connects Skiathos to the mainland and neighboring islands at any hour of the day or night."
      />
      
      <div id="routes" class="routes-grid">
        {transferRoutes.map(route => (
          <ServiceCard 
            icon={route.data.icon}
            title={route.data.title}
            description={route.data.description}
            href={route.data.href}
            price={route.data.price}
            accent={route.data.accent as any}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Advantages -->
  <section class="section section--muted">
    <div class="container">
      <div class="grid-layout">
        <div class="advantage reveal">
          <div class="adv-icon"><svg width={40} height={40} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={1.5} stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
          <h3>Zero Waiting</h3>
          <p>We depart when you arrive. Whether your flight is early or your dinner runs late, your boat is ready when you are.</p>
        </div>
        <div class="advantage reveal">
          <div class="adv-icon"><svg width={40} height={40} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={1.5} stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1Z"/><path d="m9 12 2 2 4-4"/></svg></div>
          <h3>Safe & Professional</h3>
          <p>Our fleet consists of high-spec RIBs and commercial-grade transfer boats, operated by licensed professional mariners.</p>
        </div>
        <div class="advantage reveal">
          <div class="adv-icon"><svg width={40} height={40} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={1.5} stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg></div>
          <h3>Door-to-Door</h3>
          <p>We can drop you at your hotel's private jetty, any beach, or the closest point to your villa on the coast.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 800px;">
      <SectionHeading label="Information" title="Taxi Service FAQ" />
      <FaqAccordion items={transferFaqs} />
    </div>
  </section>

  <CtaBanner
    title="Need a Transfer?"
    subtitle="Book your transfer in advance — guaranteed seats, no waiting at the dock."
    buttonText={`Call ${site?.phone?.replace(/ /g, '') || '+30XXXXXXXXXX'}`}
    buttonHref={`tel:${site?.phone?.replace(/ /g, '') || '+30XXXXXXXXXX'}`}
    variant="navy"
    backgroundImage="/images/stock/aerial_view_of_beach_and_forest.webp"
  />

  <ReviewSlider reviews={testimonials} serviceFilter="Transfer" />
</Layout>

<style>
  .section { padding: 5rem 0; }
  .section--muted { background: var(--muted); }

  .routes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .grid-layout {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 3rem;
  }

  .advantage {
    text-align: center;
    background: var(--card);
    padding: 2.5rem;
    border-radius: var(--radius-2xl);
    border: 1px solid var(--border);
  }

  .adv-icon { color: var(--foreground); display: flex; justify-content: center; margin-bottom: 1.5rem; }
  .advantage h3 { color: var(--foreground); font-size: 1.25rem; margin-bottom: 0.75rem; }
  .advantage p { color: var(--muted-foreground); font-size: 0.95rem; line-height: 1.6; }
</style>
