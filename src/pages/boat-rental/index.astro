---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/layout/PageHeader.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import ServiceCard from '../../components/cards/ServiceCard.astro';
import BoatCard from '../../components/cards/BoatCard.astro';
import PricingTable from '../../components/sections/PricingTable.astro';
import FaqAccordion from '../../components/sections/FaqAccordion.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import ReviewSlider from '../../components/sections/ReviewSlider.astro';
import DynamicIcon from '../../components/ui/DynamicIcon.astro';
import { getCollection, getEntry } from 'astro:content';
import { getFleet } from '../../lib/collections';

const boats = await getFleet();

const allActivities = await getCollection('activities');
const rentalCategories = allActivities
  .filter(a => a.data.category === 'rental')
  .sort((a, b) => a.data.order - b.data.order);

const allFaqs = await getCollection('faqs');
const rentalFaqs = allFaqs
  .filter(f => f.data.category === 'boat-rental')
  .map(f => f.data);

const rentalData = await getEntry('site', 'rental');
const steps = rentalData?.data.steps || [];
const pricingRows = rentalData?.data.pricingSummary ?? [];

const allTestimonials = await getCollection('testimonials');
const testimonials = allTestimonials
  .map((entry) => entry.data)
  .sort((a, b) => (b.featured === true ? 1 : 0) - (a.featured === true ? 1 : 0))
  .slice(0, 10);
---

<Layout
  title="Rent a Boat in Skiathos | No License Required | Sea Skiathos"
  description="Self-drive boat rental in Skiathos, Greece. No license needed for 30HP boats. RIBs, sailboats, and luxury yachts also available. Half-day, full-day and weekly hire."
>
  <PageHeader
    title="Rent a Boat in Skiathos"
    subtitle="Your own private boat, your own schedule. No license needed for smaller engines — just show up and sail."
    showBreadcrumbs={false}
  />

  <!-- Categories -->
  <section class="section">
    <div class="container">
      <h2 class="sr-only">Boat Rental Categories</h2>
      <div class="cat-grid">
        {rentalCategories.map((cat) => (
          <ServiceCard
            icon={cat.data.icon}
            title={cat.data.title}
            description={cat.data.description}
            href={cat.data.href}
            price={cat.data.price}
            accent={cat.data.accent as any}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Fleet Preview -->
  <section class="section section--muted">
    <div class="container">
      <SectionHeading
        label="Our Fleet"
        title="Available Boats"
        description="Browse our collection of vessels, each suited to a different type of adventure."
      />
      <div class="fleet-grid">
        {boats.map((boat) => (
          <BoatCard
            name={boat.data.name}
            type={boat.data.type}
            priceFrom={boat.data.priceFrom}
            priceHalfDay={boat.data.priceHalfDay}
            priceFullDay={boat.data.priceFullDay}
            slug={boat.id}
            image={boat.data.image}
            imagePlaceholder={boat.data.imagePlaceholder}
            features={boat.data.features}
            specs={[
              { label: 'Length', value: boat.data.length },
              { label: 'Capacity', value: `${boat.data.capacity} pers.` },
              { label: 'Engine', value: `${boat.data.horsepower} HP` },
            ]}
          />
        ))}
      </div>
      <div class="section-cta">
        <a href="/fleet/" class="btn-primary">Full Fleet Details</a>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section">
    <div class="container">
      <SectionHeading
        label="Simple Process"
        title="How It Works"
        description="From booking to open water in four easy steps."
      />
      <div class="steps-grid">
        {steps.map((s) => (
          <div class="step reveal">
            <span class="step-num">
              {s.icon ? (
                <DynamicIcon name={s.icon} size={28} strokeWidth={1.5} />
              ) : (
                s.step
              )}
            </span>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section section--muted">
    <div class="container" style="max-width: 800px;">
      <SectionHeading
        label="Transparent Pricing"
        title="Rental Prices at a Glance"
        description="No hidden fees. All prices include standard equipment. Fuel and security deposits apply."
      />
      <PricingTable
        rows={pricingRows}
        disclaimer="Prices might change based on seasonal availability. Fuel is not included in the price shown and is calculated at the end of the rental based on consumption. Deposits held by card, returned same day on boat return."
      />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 780px;">
      <SectionHeading
        label="Got Questions?"
        title="Frequently Asked Questions"
      />
      <FaqAccordion items={rentalFaqs} />
    </div>
  </section>

  <CtaBanner
    title="Ready to Rent a Boat in Skiathos?"
    subtitle="Contact us for availability and a free quote. We reply within 2 hours."
    buttonText="Request a Quote"
    buttonHref="/contact/"
    secondButtonText="View All Tours"
    secondButtonHref="/private-boat-tours/"
    variant="dark"
    backgroundImage="/images/stock/two_sailboats_moored_in_blue_water.webp"
  />

  <ReviewSlider reviews={testimonials} serviceFilter="Boat Rental" />
</Layout>

<style>
  .section { padding: 5rem 0; }
  .section--muted { background: var(--muted); }

  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.25rem;
  }

  .fleet-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .step {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 2rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    transition: transform 0.3s ease;
  }

  .step:hover {
    transform: translateY(-5px);
  }

  .step-num {
    color: var(--foreground);
    display: flex;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .step h3 {
    font-size: 1.25rem;
    color: var(--foreground);
    margin: 0;
  }

  .step p {
    font-size: 0.95rem;
    color: var(--muted-foreground);
    margin: 0;
    line-height: 1.6;
  }

  .section-cta {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }
</style>
