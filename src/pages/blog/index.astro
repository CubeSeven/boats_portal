---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/layout/PageHeader.astro';
import BlogCard from '../../components/cards/BlogCard.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = (allPosts || []).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPost = sortedPosts.length > 0 ? (sortedPosts.find(p => p.data.featured) || sortedPosts[0]) : null;
const remainingPosts = featuredPost ? sortedPosts.filter(p => p.id !== featuredPost.id) : sortedPosts;

const categories = ['guide', 'tips', 'destination', 'comparison'];
---

<Layout 
  title="Skiathos Travel Blog & Boat Guide | Sea Skiathos"
  description="Expert tips, hidden beach guides, and boating itineraries for Skiathos. Our local blog helps you plan the perfect day on the Aegean."
>
  <PageHeader
    title="Skiathos Sea Journal"
    subtitle="Insider guides, hidden coves, and expert boating tips from the locals who know the island best."
    showBreadcrumbs={false}
  />

  <section class="section">
    <div class="container">
      {featuredPost && (
        <>
          <div class="featured-post reveal">
            <a href={`/blog/${featuredPost.id}/`} class="featured-card">
              <div class="featured-card__image" style={featuredPost.data.image ? `background-image: url('${featuredPost.data.image}'); background-size: cover; background-position: center;` : `background: linear-gradient(135deg, var(--color-black), var(--color-gray-900))`}></div>
              <div class="featured-card__content">
                <span class="category-badge">{featuredPost.data.category}</span>
                <h2>{featuredPost.data.title}</h2>
                <p>{featuredPost.data.description}</p>
                <div class="featured-card__footer">
                  <span>{featuredPost.data.pubDate.toLocaleDateString()}</span>
                  <span>•</span>
                  <span>{featuredPost.data.readTime} min read</span>
                </div>
              </div>
            </a>
          </div>
        </>
      )}


      <div class="blog-layout">
        <main class="blog-grid">
          {remainingPosts.map(post => (
            <BlogCard
              title={post.data.title}
              excerpt={post.data.description}
              slug={post.id}
              pubDate={post.data.pubDate.toISOString()}
              readTime={String(post.data.readTime)}
              category={post.data.category}
              imagePlaceholder={post.data.imagePlaceholder}
              image={post.data.image}
            />
          ))}
        </main>
        
        <aside class="blog-sidebar">
          <div class="sidebar-box">
            <h3>Categories</h3>
            <div class="category-links">
              {categories.map(cat => (
                <a href={`/blog/?category=${cat}`} class="cat-link text-capitalize">{cat}</a>
              ))}
            </div>
          </div>
          
        </aside>
      </div>
    </div>
  </section>

  <CtaBanner
    title="Plan Your Perfect Skiathos Day"
    subtitle="Our team is ready to help you build a custom itinerary based on our local knowledge."
    buttonText="Contact the Experts"
    buttonHref="/contact/"
    variant="turquoise"
    backgroundImage="/images/stock/s19tock-images.webp"
  />
</Layout>

<style>
  .section { padding: 4rem 0; }

  .featured-post { margin-bottom: 4rem; }
  .featured-card {
    display: grid;
    grid-template-columns: 1fr;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-2xl);
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.3s ease;
  }
  @media (min-width: 1024px) { .featured-card { grid-template-columns: 1.2fr 1fr; } }
  .featured-card:hover { transform: translateY(-5px); }
  .featured-card__image { min-height: 300px; }
  .featured-card__content { padding: 2.5rem; display: flex; flex-direction: column; gap: 1rem; }
  .featured-card__content h2 { font-size: 2rem; color: var(--foreground); margin: 0; font-weight: 800; letter-spacing: -0.02em; }
  .featured-card__content p { font-size: 1.1rem; color: var(--muted-foreground); line-height: 1.6; }
  
  .category-badge {
    background: var(--color-black);
    color: var(--color-white);
    padding: 0.35rem 0.85rem;
    border-radius: 2px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    width: fit-content;
    letter-spacing: 0.1em;
  }

  .blog-layout { display: grid; grid-template-columns: 1fr; gap: 3rem; }
  @media (min-width: 1024px) { .blog-layout { grid-template-columns: 1fr 300px; } }

  .blog-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; }
  
  .blog-sidebar { display: flex; flex-direction: column; gap: 2rem; }
  .sidebar-box { padding: 2rem; background: var(--color-gray-50); border: 1px solid var(--border); border-radius: var(--radius-sm); }
  .sidebar-box h3 { margin-top: 0; font-size: 1.25rem; color: var(--foreground); margin-bottom: 1.25rem; font-weight: 700; }
  
  .category-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .cat-link {
    background: var(--background);
    border: 1px solid var(--border);
    padding: 0.45rem 0.9rem;
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    text-decoration: none;
    color: var(--foreground);
    transition: all 0.2s;
    font-weight: 500;
  }
  .cat-link:hover { border-color: var(--foreground); background: var(--color-black); color: var(--color-white); }
  
  .sticky-sidebar { position: sticky; top: 120px; }
  
  .featured-card__footer { display: flex; gap: 0.75rem; font-size: 0.85rem; color: var(--muted-foreground); margin-top: auto; font-weight: 500; }
</style>

