---
import ServicePage from '../../layouts/ServicePage.astro';
import PricingTable from '../../components/sections/PricingTable.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('activities', 'tubes-inflatables');
const { Content } = await render(entry);
const data = entry.data;

const highlights = data.highlights || [];
const features = data.features || [];
const pricing = data.pricing || [];
const faqs = data.faqs || [];
---

<ServicePage
  id={entry.id}
  category={data.category}
  title={data.seoTitle}
  seoTitle={data.seoTitle}
  description={data.description}
  heroTitle={data.heroTitle}
  heroSubtitle={data.heroSubtitle}
  heroGradient={data.heroGradient as any}
  faqs={faqs}
>
  <section>
    <SectionHeading
      label="Group Fun"
      title="Towable Experiences"
      align="left"
      titleSize="md"
    />
    <Content />

    {highlights.length > 0 && (
      <div class="towable-grid">
        {highlights.map(h => (
          <div class="towable-card">
            <h3>{h.title}</h3>
            <p>{h.description}</p>
          </div>
        ))}
      </div>
    )}
  </section>

  {pricing.length > 0 && (
    <section>
      <SectionHeading
        label="Pricing"
        title="Ride Rates"
        align="left"
        titleSize="md"
      />
      <PricingTable rows={pricing} disclaimer="All prices are per person. Minimum 2 riders for Sofa and Slider." />
    </section>
  )}

  {features.length > 0 && (
    <section>
      <SectionHeading
        label="Safety"
        title="Professional Skippers"
        align="left"
        titleSize="md"
      />
      <p>
        Our boat drivers are certified professionals who prioritize your safety. They use hand signals to communicate with you throughout the ride, allowing you to signal for more speed or a slower pace at any time.
      </p>
      <ul>
        {features.map(f => (
          <li>{f}</li>
        ))}
      </ul>
    </section>
  )}
</ServicePage>

<style>
  .towable-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0;
  }
  .towable-card {
    background: var(--muted);
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
  }
  .towable-card h3 {
    font-size: 1.1rem;
    color: var(--foreground);
    margin-bottom: 0.5rem;
  }
  .towable-card p {
    font-size: 0.9rem;
    margin: 0;
  }
</style>
