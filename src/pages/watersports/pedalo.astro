---
import ServicePage from '../../layouts/ServicePage.astro';
import PricingTable from '../../components/sections/PricingTable.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('activities', 'pedalo');
if (!entry) throw new Error('Activity "pedalo" not found');
const { Content } = await render(entry);
const data = entry.data;

const pricing = data.pricing || [];
const faqs = data.faqs || [];
---

<ServicePage
  id={entry.id}
  category={data.category}
  title={data.seoTitle}
  seoTitle={data.seoTitle}
  description={data.description}
  heroTitle={data.heroTitle}
  heroSubtitle={data.heroSubtitle}
  heroGradient={data.heroGradient as any}
  faqs={faqs}
>
  <section>
    <SectionHeading
      label="Pedal & Paddle"
      title="Cycle Your Way Across the Bay"
      align="left"
      titleSize="md"
    />
    <Content />
  </section>

  {pricing.length > 0 && (
    <section>
      <SectionHeading
        label="Pricing"
        title="Pedalo Hire Rates"
        align="left"
        titleSize="md"
      />
      <PricingTable rows={pricing} disclaimer="Includes life jackets for all sizes. Kids must be accompanied by an adult." />
    </section>
  )}
</ServicePage>

<style>
</style>
