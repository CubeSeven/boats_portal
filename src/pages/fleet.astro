---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/layout/PageHeader.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import BoatCard from '../components/cards/BoatCard.astro';
import PricingTable from '../components/sections/PricingTable.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
import ReviewSlider from '../components/sections/ReviewSlider.astro';
import { getFleet, getOrganizedFaqs, getSiteSettings } from '../lib/collections';
import { getEntry, getCollection } from 'astro:content';

const boats = await getFleet();

const faqsByCategory = await getOrganizedFaqs();
const fleetFaqs = faqsByCategory['fleet'] || [];

const rentalData = await getEntry('site', 'rental');
const pricingRows = rentalData?.data.pricingSummary ?? [];

const allTestimonials = await getCollection('testimonials');
const testimonials = allTestimonials
  .map((entry) => entry.data)
  .sort((a, b) => (b.featured === true ? 1 : 0) - (a.featured === true ? 1 : 0))
  .slice(0, 10);
---

<Layout
  title="Our Fleet — Sea Skiathos | RIBs, Yachts & Self-Drive Rentals"
  description="Explore the full Sea Skiathos fleet. From beginner-friendly 30HP motorboats to high-speed rigid inflatables and luxury crewed yachts. Perfect for any Aegean adventure."
>
  <PageHeader
    title="The Fleet"
    subtitle="From nimble coastal explorers to high-performance offshore vessels. Find the perfect boat for your Skiathos adventure."
    showBreadcrumbs={false}
  />

  <section class="section">
    <div class="container">
      <h2 class="sr-only">Our Boats</h2>
      <div class="grid-cards">
        {boats.map((boat) => (
          <BoatCard
            name={boat.data.name}
            type={boat.data.type}
            priceFrom={boat.data.priceFrom}
            priceHalfDay={boat.data.priceHalfDay}
            priceFullDay={boat.data.priceFullDay}
            slug={boat.id}
            image={boat.data.image}
            imagePlaceholder={boat.data.imagePlaceholder}
            features={boat.data.features}
            specs={[
              { label: 'Length', value: boat.data.length },
              { label: 'Capacity', value: `${boat.data.capacity} pers.` },
              { label: 'Engine', value: `${boat.data.horsepower} HP` },
            ]}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section section-muted">
    <div class="container max-w-3xl">
      <SectionHeading
        label="Quick Rates"
        title="Standard Fleet Pricing"
        description="Base rates for our most popular vessels. Contact us for multi-day discounts and seasonal specials."
      />
      <PricingTable rows={pricingRows} disclaimer="Prices might change based on seasonal availability. Fuel is not included in the price shown and is calculated at the end of the rental based on consumption. Security deposits vary by vessel type." />
    </div>
  </section>

  <section class="section">
    <div class="container max-w-3xl">
      <SectionHeading
        label="Fleet FAQ"
        title="Vessel & Equipment Questions"
      />
      <FaqAccordion items={fleetFaqs} />
    </div>
  </section>

  <CtaBanner
    title="Your Adventure Starts Here"
    subtitle="Browse the full fleet and reserve your boat in minutes. No booking fees, free cancellation up to 48h before."
    buttonText="Ask an Expert"
    buttonHref="/contact/"
    variant="dark"
    backgroundImage="/images/stock/many_sailboats_racing_on_blue_water.webp"
  />

  <ReviewSlider reviews={testimonials} serviceFilter="Boat Rental" />
</Layout>

<style>
  .mt-12 { margin-top: 3rem; }
  .max-w-3xl { max-width: 48rem; margin-inline: auto; }
</style>
