---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import TourCard from '../../components/cards/TourCard.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import ReviewSlider from '../../components/sections/ReviewSlider.astro';
import { getSortedTours } from '../../lib/collections';
import { getCollection } from 'astro:content';

// Load content from CMS
const tours = await getSortedTours();

// Get featured testimonials from CMS
const allTestimonials = await getCollection('testimonials');
const testimonials = allTestimonials
  .map((entry) => entry.data)
  .sort((a, b) => (b.featured === true ? 1 : 0) - (a.featured === true ? 1 : 0))
  .slice(0, 10);
---

<Layout 
  title="Private Boat Tours Skiathos | Exclusive Sea Experiences"
  description="Exclusive private boat tours in Skiathos. Visit Lalaria, Skopelos, Kastro, and hidden sea caves with your own local skipper. Tailored itineraries."
>
  <HeroSection
    title="Private Boat Tours<br/>in Skiathos"
    subtitle="Skip the crowds. Book an exclusive private boat trip with a local skipper and discover the hidden side of the Aegean."
    ctaText="Book a Tour"
    ctaHref="/contact/"
    ctaSecondText="Special Offers"
    ctaSecondHref="/blog/"
    gradient="turquoise"
    size="medium"
    showScrollHint={false}
    backgroundImage="/images/stock/Boat_passing_near_small_islands.webp"
  />

  <Breadcrumbs />

  <!-- Intro -->
  <section class="section">
    <div class="container">
      <SectionHeading
        label="Exclusive Experiences"
        title="Why Choose a Private Tour?"
        description="Unlike the large tour boats, our private trips are entirely about you. No strangers, no rigid schedules — just your group and the sea."
      />
      
      <div class="features-grid">
        <div class="feature reveal">
          <div class="feature-icon"><svg width={32} height={32} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={1.5} stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="3"/><line x1="12" y1="22" x2="12" y2="8"/><path d="M5 12H2a10 10 0 0 0 20 0h-3"/></svg></div>
          <h3>Tailored Itinerary</h3>
          <p>Want to stay longer at Lalaria? Skip a busy spot? It's your boat. You decide where we stop and for how long.</p>
        </div>
        <div class="feature reveal">
          <div class="feature-icon"><svg width={32} height={32} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={1.5} stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 0 0-16 0"/></svg></div>
          <h3>Expert Local Skipper</h3>
          <p>Our skippers know the secret coves the big boats can't reach and the best times to avoid the crowds.</p>
        </div>
        <div class="feature reveal">
          <div class="feature-icon"><svg width={32} height={32} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={1.5} stroke-linecap="round" stroke-linejoin="round"><path d="M8 22h8"/><path d="M7 10h10"/><path d="M12 15v7"/><path d="M12 15a5 5 0 0 0 5-5c0-2-.5-4-2-8H9c-1.5 4-2 6-2 8a5 5 0 0 0 5 5Z"/></svg></div>
          <h3>Premium Service</h3>
          <p>Chilled water, snorkelling gear, and high-quality safety equipment are included in every private tour.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tour List -->
  <section class="section section--muted">
    <div class="container">
      <SectionHeading
        label="Our Trip Menu"
        title="Featured Sea Experiences"
        description="Choose one of our curated itineraries or ask us to build a completely custom day at sea."
      />
      
      <div class="tours-grid">
        {tours.map(tour => (
          <TourCard
            title={tour.data.title}
            description={tour.data.description}
            href={`/private-boat-tours/${tour.id}/`}
            price={tour.data.pricing?.[0]?.price}
            image={tour.data.image}
            badge={tour.data.duration}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <ReviewSlider reviews={testimonials} serviceFilter="Private Tour" />

  <CtaBanner
    title="Ready for a Private Adventure?"
    subtitle="Contact us to check availability for your preferred date. We respond within 2 hours."
    buttonText="Check Availability"
    buttonHref="/contact/"
    variant="dark"
    backgroundImage="/images/stock/Straw_hat_rests_beside_blue_pool.webp"
  />
</Layout>

<style>
  .section { padding: 5rem 0; }
  .section--muted { background: var(--muted); }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .feature {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 2rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    transition: transform 0.3s ease;
  }

  .feature:hover {
    transform: translateY(-5px);
  }

  .feature-icon {
    color: var(--foreground);
    display: flex;
    align-items: center;
  }

  .feature h3 {
    font-size: 1.25rem;
    color: var(--foreground);
    margin: 0;
  }

  .feature p {
    font-size: 0.95rem;
    color: var(--muted-foreground);
    line-height: 1.6;
    margin: 0;
  }

  .tours-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
</style>
