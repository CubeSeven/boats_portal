---
import Layout from '../layouts/Layout.astro';

// 404 Page - Monochromatic "Lost at Sea" Theme
---

<Layout 
  title="404: Lost at Sea — Sea Skiathos"
  description="The page you are looking for could not be found. Return to safe harbor."
>
  <main class="error-page-v2">
    <!-- Rigid Grid Cell -->
    <div class="grid place-items-center min-h-[80vh] px-6">
      
      <div class="max-w-screen-md w-full relative">
        
        <!-- Layer 0: Background Decorative (Isolated) -->
        <div class="absolute inset-0 flex items-center justify-center opacity-[0.03] select-none pointer-events-none -z-10">
          <span class="text-[15rem] md:text-[25rem] font-black tracking-tighter">404</span>
        </div>

        <!-- Layer 1: Foreground Content -->
        <div class="relative z-10 flex flex-col items-center">
          <div class="mb-12">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-foreground opacity-20">
              <circle cx="12" cy="12" r="10"/>
              <path d="M16.2 7.8 12 12l-4.2 4.2"/>
              <path d="m7.8 7.8 8.4 8.4"/>
            </svg>
          </div>

          <h1 class="text-5xl md:text-7xl font-black tracking-tighter m-0 mb-6 uppercase italic">
            Lost at Sea.
          </h1>
          
          <p class="text-lg md:text-xl text-muted-foreground font-medium max-w-md mb-12">
            The page you're looking for has drifted off the map. Let's get you back to familiar waters.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
            <a href="/" class="btn btn-primary px-8 py-4 text-xs tracking-widest uppercase">
              Return to Safe Harbor
            </a>
            <a href="/contact/" class="btn btn-secondary px-8 py-4 text-xs tracking-widest uppercase">
              Contact Support
            </a>
          </div>
        </div>

      </div>
    </div>
  </main>
</Layout>

<style>
  .error-page-v2 {
    background-color: var(--background);
    background-image: 
      radial-gradient(at 0% 0%, oklch(0 0 0 / 2%) 0, transparent 50%), 
      radial-gradient(at 50% 0%, oklch(0 0 0 / 2%) 0, transparent 50%);
  }
</style>
