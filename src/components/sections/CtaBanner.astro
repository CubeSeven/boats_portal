---
import Picture from '../ui/Picture.astro';

interface Props {
  title: string;
  subtitle?: string;
  buttonText?: string;
  buttonHref?: string;
  secondButtonText?: string;
  secondButtonHref?: string;
  variant?: 'dark' | 'light' | 'muted' | 'navy' | 'ocean' | 'turquoise';
  backgroundImage?: string;
}

const {
  title,
  subtitle,
  buttonText = 'Book Now',
  buttonHref = '/contact/',
  secondButtonText,
  secondButtonHref = '#',
  variant = 'dark',
  backgroundImage,
} = Astro.props;

const variantClasses = {
  dark: 'bg-black text-white',
  light: 'bg-white text-black border border-border/50',
  muted: 'bg-muted/30 text-foreground',
  navy: 'bg-black text-white',
  ocean: 'bg-black text-white',
  turquoise: 'bg-muted/30 text-foreground',
};
---

<div class="container hidden md:block">
  <section class={`relative overflow-hidden my-12 md:my-32 rounded-[2rem] ${variantClasses[variant]}`} aria-label="Call to action">
    {backgroundImage && (
      <div class="absolute inset-0 pointer-events-none z-0 overflow-hidden" aria-hidden="true">
        <Picture src={backgroundImage} alt="" class="w-full h-full object-cover opacity-35" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/45 to-black/20"></div>
      </div>
    )}
    {variant === 'dark' && !backgroundImage && (
      <div class="absolute inset-0 pointer-events-none opacity-20" aria-hidden="true">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_-20%,_var(--color-gray-800),_transparent)]"></div>
      </div>
    )}

    <div class="px-8 md:px-16 py-16 md:py-24 relative z-10">
      <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-12">
        <div class="flex flex-col gap-6 max-w-2xl reveal">
          <h2 class="text-3xl md:text-5xl font-semibold tracking-tight leading-tight m-0 text-current">{title}</h2>
          {subtitle && <p class="text-lg opacity-70 m-0 leading-relaxed font-normal">{subtitle}</p>}
        </div>
        
        <div class="flex gap-4 flex-wrap items-center reveal">
          <a href={buttonHref} class={`btn ${variant === 'dark' ? 'bg-white text-black border-white hover:bg-transparent hover:text-white' : 'btn-primary'} px-8 py-4`}>
            {buttonText}
          </a>
          {secondButtonText && (
            <a href={secondButtonHref} class={`btn ${variant === 'dark' ? 'border-white/20 text-white hover:border-white' : 'btn-secondary'} px-8 py-4`}>
              {secondButtonText}
            </a>
          )}
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  section {
    /* Subtle inner-glow for dark variant */
    box-shadow: 0 40px 100px -30px rgba(0,0,0,0.1);
  }
  
  .dark section {
    box-shadow: 0 40px 100px -30px rgba(0,0,0,0.5);
  }
</style>
