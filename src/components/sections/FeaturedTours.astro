---
import SectionHeading from '../ui/SectionHeading.astro';
import TourCard from '../cards/TourCard.astro';

interface Props {
  tours: any[];
}

const { tours } = Astro.props;
---
<section class="section" id="tours">
  <div class="container">
    <SectionHeading
      label="Private Boat Tours"
      title="Popular Tours"
      description="Exclusive, private, and tailored to your group. No strangers — just you and the Aegean."
    />
    <div class="grid-cards">
      {tours.map((tour) => (
        <TourCard
          title={tour.data.title}
          description={tour.data.description}
          href={`/private-boat-tours/${tour.id}/`}
          price={tour.data.pricing?.[0]?.price}
          image={tour.data.image}
          badge={tour.data.duration}
        />
      ))}
    </div>
    <div class="flex justify-center mt-10">
      <a href="/private-boat-tours/" class="btn btn-primary">View All Private Tours</a>
    </div>
  </div>
</section>
