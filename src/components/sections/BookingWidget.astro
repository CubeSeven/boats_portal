---
import { getFleet, getSortedTours, getSortedServices } from '../../lib/collections';
import { getCollection } from 'astro:content';

interface Props {
  initialService?: string; // e.g. "boat-rental", "private-tours"
  initialSubId?: string; // e.g. "nordkapp-23"
}

const { initialService = '', initialSubId = '' } = Astro.props;

// Load collections to populate the select menu
const fleet = await getFleet();
const tours = await getSortedTours();
const services = await getSortedServices();
const routes = await getCollection('routes');
const activities = await getCollection('activities');

// Flatten all items for the dropdown
const allItems = [
  ...fleet.filter(b => b.data.available !== false).map(b => ({ id: b.id, service: 'boat-rental', name: b.data.name, label: `Rent ${b.data.name}` })),
  ...tours.map(t => ({ id: t.id, service: 'private-tours', name: t.data.title, label: t.data.title })),
  ...routes.map((r: any) => ({ id: r.id, service: 'transfers', name: `${r.data.fromLocation} → ${r.data.toLocation}`, label: `${r.data.fromLocation} → ${r.data.toLocation}` })),
  ...activities.filter((a: any) => a.data.category === 'watersports').map((a: any) => ({ id: a.id, service: 'watersports', name: a.data.title, label: a.data.title }))
];
---

<div class="booking-widget" data-initial-service={initialService} data-initial-sub={initialSubId}>
  <div class="booking-widget__header">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
      <line x1="16" y1="2" x2="16" y2="6"/>
      <line x1="8" y1="2" x2="8" y2="6"/>
      <line x1="3" y1="10" x2="21" y2="10"/>
    </svg>
    <span>Check Availability</span>
  </div>

  <form class="booking-form" id="inline-booking-trigger" aria-label="Quick booking context">
    <div class="form-row">
      <div class="form-field">
        <label for="bw-service">Select Option</label>
        <select id="bw-service" name="service" required>
          <option value="" disabled selected>Choose an option…</option>
          {services.map(s => (
            <optgroup label={s.data.title}>
              {allItems.filter(item => item.service === s.id).map(item => (
                <option value={`${item.service}|${item.id}`} selected={initialService === item.service && initialSubId === item.id}>
                  {item.label}
                </option>
              ))}
              <option value={`${s.id}|custom`}>Custom {s.data.title} Request</option>
            </optgroup>
          ))}
          <option value="custom|custom">Other / General Inquiry</option>
        </select>
      </div>
    </div>

    <div class="form-row form-row--2">
      <div class="form-field">
        <label for="bw-date">Date</label>
        <input type="date" id="bw-date" name="date" required />
      </div>
      <div class="form-field">
        <label for="bw-guests">Guests</label>
        <input type="number" id="bw-guests" name="guests" min="1" max="30" placeholder="e.g. 4" />
      </div>
    </div>

    <button type="submit" class="booking-submit btn btn-primary">
      <span>Continue Booking</span>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>
  </form>
</div>

<style>
  .booking-widget {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: 0 8px 32px oklch(0 0 0 / 8%);
  }

  .booking-widget__header {
    background: var(--foreground);
    color: white;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 700;
    font-size: 0.95rem;
  }

  .booking-form {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-row {
    display: grid;
    gap: 1rem;
  }

  .form-row--2 {
    grid-template-columns: 1fr 1fr;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--foreground);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  input,
  select {
    padding: 0.65rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--background);
    color: var(--foreground);
    font-size: 0.9rem;
    font-family: var(--font-sans);
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
    width: 100%;
  }

  input:focus,
  select:focus {
    border-color: var(--foreground);
    outline: none;
    box-shadow: 0 0 0 2px var(--foreground);
  }

  input::placeholder {
    color: var(--muted-foreground);
  }
  
  optgroup {
    font-weight: 700;
    font-family: var(--font-sans);
  }

  .booking-submit {
    width: 100%;
    margin-top: 0.5rem;
    height: 3.25rem;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .booking-submit svg {
    transition: transform var(--duration-normal) var(--ease-premium);
  }

  .booking-submit:hover svg {
    transform: translateX(3px);
  }

  .booking-submit:active {
    scale: 0.98;
  }
</style>

<script>
  document.querySelectorAll('#inline-booking-trigger').forEach(form => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const fd = new FormData(form as HTMLFormElement);
      const serviceVal = fd.get('service') as string;
      const date = fd.get('date') as string;
      const guests = fd.get('guests') as string;
      
      let serviceId = '';
      let subId = '';
      
      if (serviceVal) {
        const parts = serviceVal.split('|');
        serviceId = parts[0];
        subId = parts[1];
      }
      
      const w = window as any;
      if (w.__openBookingModal) {
        w.__openBookingModal({
          serviceId,
          subId,
          date,
          guests
        });
      }
    });
  });
</script>
