---
import Picture from '../ui/Picture.astro';

interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  ctaSecondText?: string;
  ctaSecondHref?: string;
  gradient?: 'moody' | 'airy' | 'neutral' | 'dark' | 'ocean' | 'sunset' | 'turquoise' | 'light' | 'muted';
  size?: 'full' | 'medium';
  showScrollHint?: boolean;
  label?: string;
  backgroundImage?: string;
}

const {
  title,
  subtitle,
  ctaText,
  ctaHref = '#',
  ctaSecondText,
  ctaSecondHref = '#',
  gradient = 'airy',
  size = 'full',
  showScrollHint = true,
  label = 'Skiathos, Greece',
  backgroundImage,
} = Astro.props;

const gradientClasses: Record<string, string> = {
  airy: 'bg-gradient-to-br from-neutral-900 via-neutral-950 to-black',
  moody: 'bg-gradient-to-br from-black via-neutral-900 to-neutral-950',
  neutral: 'bg-gradient-to-br from-neutral-900 via-neutral-950 to-black',
  dark: 'bg-black',
  light: 'bg-gradient-to-br from-neutral-900 via-neutral-950 to-black',
  muted: 'bg-neutral-900',
  ocean: 'bg-gradient-to-br from-slate-900 via-slate-950 to-black',
  sunset: 'bg-gradient-to-br from-neutral-900 via-black to-neutral-950',
  turquoise: 'bg-gradient-to-br from-slate-900 via-neutral-900 to-black',
  gold: 'bg-gradient-to-br from-stone-900 via-neutral-950 to-black',
  navy: 'bg-gradient-to-br from-slate-950 via-blue-950/20 to-black',
};

const sizeClasses = {
  full: 'min-h-[100svh] pb-24 md:pb-32 pt-32',
  medium: 'min-h-[65vh] pb-20 md:pb-28 pt-28',
};
---

<section class={`relative overflow-hidden flex items-end justify-start text-left px-6 md:px-10 text-white ${gradientClasses[gradient] || gradientClasses.moody} ${sizeClasses[size]}`} aria-label="Hero section">
  <!-- Background image -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    {backgroundImage ? (
      <div class="absolute inset-0 z-0 hero-zoom">
        <Picture src={backgroundImage} alt="" class="w-full h-full object-cover" loading="eager" fetchpriority="high" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/20 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-black/40 via-transparent to-transparent"></div>
      </div>
    ) : (
      <>
        <div class="absolute w-[800px] h-[800px] rounded-full blur-[150px] opacity-10 bg-white -top-40 -right-40"></div>
        <div class="absolute w-[600px] h-[600px] rounded-full blur-[120px] opacity-5 bg-neutral-400 -bottom-40 -left-40"></div>
      </>
    )}
  </div>

  <div class="container relative z-10 flex flex-col items-start gap-5 md:gap-6 max-w-5xl">
    <span class="hero-label hero-reveal" style="animation-delay: 0.1s;">{label}</span>
    <h1 class="hero-title hero-reveal" style="animation-delay: 0.25s;" set:html={title} />
    {subtitle && <p class="hero-subtitle hero-reveal" style="animation-delay: 0.4s;">{subtitle}</p>}
    
    {(ctaText || ctaSecondText) && (
      <div class="flex gap-3 md:gap-4 flex-wrap mt-2 md:mt-4 hero-reveal" style="animation-delay: 0.55s;">
        {ctaText && (
          <a href={ctaHref} class="hero-btn hero-btn-primary">
            {ctaText}
          </a>
        )}
        {ctaSecondText && (
          <a href={ctaSecondHref} class="hero-btn hero-btn-outline">
            {ctaSecondText}
          </a>
        )}
      </div>
    )}
  </div>

  {showScrollHint && size === 'full' && (
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 hero-reveal" style="animation-delay: 0.8s;" aria-hidden="true">
      <div class="hero-scroll-hint">
        <div class="hero-scroll-line"></div>
        <span class="hero-scroll-text">Scroll</span>
      </div>
    </div>
  )}

  <!-- Bottom dividing wave -->
  <div class="absolute bottom-[-1px] left-0 right-0 z-10 h-20 pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full block">
      <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="white"/>
    </svg>
  </div>
</section>
