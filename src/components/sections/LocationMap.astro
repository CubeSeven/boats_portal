---
// Placeholder — shows a static map image with pin markers
interface Location {
  label: string;
  sub?: string;
}

interface Props {
  locations?: Location[];
  height?: string;
}

const {
  locations = [
    { label: 'Skiathos Town Port', sub: 'Main base' },
    { label: 'Koukounaries Beach', sub: 'Watersports' },
    { label: 'Kanapitsa Beach', sub: 'Boat rental' },
    { label: 'Vromolimnos', sub: 'Water ski' },
  ],
  height = '320px',
} = Astro.props;
---

<div class="location-map" style={`height: ${height};`}>
  <!-- Map visual placeholder -->
  <div class="map-bg" aria-hidden="true">
    <!-- Ocean area -->
    <div class="map-ocean"></div>
    <!-- Island silhouette -->
    <div class="map-island"></div>
    <!-- Grid lines -->
    <div class="map-grid"></div>
  </div>

  <!-- Overlay markers -->
  <div class="map-markers">
    {locations.map((loc, i) => (
      <div
        class={`map-pin map-pin--${i + 1}`}
        title={loc.label}
      >
        <div class="pin-dot">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
        </div>
        <div class="pin-label">
          <strong>{loc.label}</strong>
          {loc.sub && <span>{loc.sub}</span>}
        </div>
      </div>
    ))}
  </div>

  <!-- Caption -->
  <div class="map-caption">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg>
    Map placeholder — Google Maps embed will be added here
  </div>
</div>

<style>
  .location-map {
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--border);
    position: relative;
    background: oklch(0.75 0.08 225);
  }

  /* Stylized map background */
  .map-bg {
    position: absolute;
    inset: 0;
  }

  .map-ocean {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      oklch(0.60 0.12 220) 0%,
      oklch(0.68 0.10 210) 50%,
      oklch(0.72 0.08 200) 100%
    );
  }

  .map-island {
    position: absolute;
    top: 20%;
    left: 15%;
    right: 20%;
    bottom: 30%;
    background: oklch(0.72 0.12 145);
    border-radius: 40% 55% 45% 60%;
    box-shadow: 0 4px 24px oklch(0 0 0 / 15%);
  }

  .map-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.08) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  /* Marker pins */
  .map-markers {
    position: absolute;
    inset: 0;
  }

  .map-pin {
    position: absolute;
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
  }

  /* Approximate positions */
  .map-pin--1 { top: 45%; left: 52%; }
  .map-pin--2 { top: 55%; left: 18%; }
  .map-pin--3 { top: 38%; left: 35%; }
  .map-pin--4 { top: 30%; left: 48%; }

  .pin-dot {
    width: 28px;
    height: 28px;
    background: var(--foreground);
    color: var(--background);
    border-radius: 50% 50% 50% 0;
    transform: rotate(-45deg);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 4px 12px oklch(0 0 0 / 25%);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .pin-dot svg {
    transform: rotate(45deg);
  }

  .map-pin:hover .pin-dot {
    transform: rotate(-45deg) scale(1.2);
    box-shadow: 0 6px 20px oklch(0 0 0 / 35%);
  }

  .pin-label {
    background: white;
    border-radius: var(--radius-md);
    padding: 0.3rem 0.6rem;
    display: none;
    flex-direction: column;
    box-shadow: 0 4px 16px oklch(0 0 0 / 20%);
    white-space: nowrap;
  }

  .map-pin:hover .pin-label {
    display: flex;
  }

  .pin-label strong {
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--foreground);
  }

  .pin-label span {
    font-size: 0.65rem;
    color: var(--muted-foreground);
  }

  .marker-popup p {
    color: var(--muted-foreground);
  }

  /* Caption */
  .map-caption {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(8px);
    border-radius: var(--radius-md);
    padding: 0.35rem 0.65rem;
    font-size: 0.7rem;
    color: var(--muted-foreground);
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
</style>
