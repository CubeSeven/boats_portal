---
import SectionHeading from '../ui/SectionHeading.astro';
import MultiPinMap from '../maps/MultiPinMap.astro';

interface Props {
  locations: any[];
}

const { locations } = Astro.props;
---

<section class="section section-muted" id="locations">
  <div class="container">
    <SectionHeading
      label="Where to Find Us"
      title="Our Locations"
      description="We operate from four bases — Skiathos Old Port, Skiathos New Port, Kolios Beach, and Agia Paraskevi Beach."
    />
    {locations.length > 0 && (
      <MultiPinMap
        pins={locations
          .filter((loc: any) => loc.data.latitude != null && loc.data.longitude != null)
          .map((loc: any) => ({
            lat: loc.data.latitude,
            lng: loc.data.longitude,
            label: loc.data.locationName,
            sub: loc.data.heroSubtitle,
            href: `/locations/${loc.id}/`,
          }))}
        height="400px"
      />
    )}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mt-8">
      {locations.map((loc) => (
        <div class="reveal">
          <a href={`/locations/${loc.id}/`} class="card group flex items-center gap-4">
            <div class="card-content flex-row items-center gap-4 p-4">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 opacity-40"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <div class="flex flex-col">
                <strong class="text-sm font-bold tracking-tight">{loc.data.locationName}</strong>
                <span class="text-[0.65rem] text-muted-foreground">{loc.data.heroSubtitle}</span>
              </div>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
