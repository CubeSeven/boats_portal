---
interface PricingRow {
  duration: string;
  price: string;
  notes?: string;
  highlight?: boolean;
}

interface Props {
  title?: string;
  rows: PricingRow[];
  currency?: string;
  disclaimer?: string;
}

const {
  title,
  rows,
  currency = '€',
  disclaimer,
} = Astro.props;
---

<div class="pricing-table flex flex-col gap-5 my-6">
  {title && <h3 class="text-xl font-bold tracking-tight m-0 text-current">{title}</h3>}
  <div class="pricing-table__wrap overflow-x-auto rounded-xl border border-border bg-card">
    <table class="w-full border-collapse text-[0.95rem]">
      <thead>
        <tr class="bg-foreground text-background">
          <th class="p-4 text-left text-[0.65rem] font-extrabold tracking-widest uppercase">Duration</th>
          <th class="p-4 text-left text-[0.65rem] font-extrabold tracking-widest uppercase">Price ({currency})</th>
          <th class="p-4 text-left text-[0.65rem] font-extrabold tracking-widest uppercase hidden sm:table-cell">Notes</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr class={`border-b border-border last:border-none transition-colors hover:bg-muted/50 ${row.highlight ? 'bg-muted/30 border-l-4 border-l-current' : ''}`}>
            <td class="p-4 font-bold text-current">
              <div class="flex items-center gap-3 flex-wrap">
                {row.highlight && <span class="bg-foreground text-background text-[0.6rem] font-extrabold uppercase tracking-widest px-2 py-0.5 rounded-full">Special</span>}
                {row.duration}
              </div>
            </td>
            <td class="p-4 font-extrabold text-lg tracking-tight text-current">{row.price}</td>
            <td class="p-4 text-[0.85rem] opacity-70 hidden sm:table-cell">{row.notes ?? '—'}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  {disclaimer && <p class="text-[0.85rem] opacity-60 m-0 pt-4 border-t border-border italic">{disclaimer}</p>}
</div>
