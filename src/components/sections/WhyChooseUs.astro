---
import SectionHeading from '../ui/SectionHeading.astro';
import DynamicIcon from '../ui/DynamicIcon.astro';

interface Props {
  items: Array<{
    title: string;
    desc: string;
    icon: string;
  }>;
}

const { items = [] } = Astro.props;
---

<section class="section relative text-white overflow-hidden py-20 md:py-28" id="why-us" style="background-image: url('/images/stock/boat_moored_near_rocky_cliff_beach.webp');">
  <div class="absolute inset-0 bg-black/65 z-0"></div>
  <div class="container relative z-10">
    <SectionHeading
      label="The Local Experts"
      title="Why Sea Skiathos"
      description="We've been on this water our whole lives. Here's what that means for you."
      align="center"
      dark={true}
    />
    <div class="grid-cards mt-12">
      {items.map((item) => (
        <div class="glass-card flex flex-col gap-4 p-8 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md transition-all duration-300 hover:bg-white/10 hover:border-white/20 hover:-translate-y-1 shadow-lg reveal">
          <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-white/10 text-white shrink-0">
            <DynamicIcon name={item.icon} size={24} strokeWidth={1.5} />
          </div>
          <div class="flex flex-col gap-2">
            <h3 class="text-white text-lg font-extrabold tracking-tight m-0">{item.title}</h3>
            <p class="text-white/80 text-sm leading-relaxed m-0">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #why-us {
    background-attachment: fixed;
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
  }
  @media (max-width: 768px) {
    #why-us {
      background-attachment: scroll;
    }
  }
</style>
