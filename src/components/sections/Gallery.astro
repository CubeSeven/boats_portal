---
import 'glightbox/dist/css/glightbox.css';
import Picture from '../ui/Picture.astro';

interface GalleryItem {
  src: string;
  alt: string;
}

interface Props {
  items?: (GalleryItem | string)[];
  title?: string;
}

const {
  items = [],
  title,
} = Astro.props;

// Normalize items — generate descriptive alt text from title context
const normalizedItems: GalleryItem[] = items.map((item, index) => {
  if (typeof item === 'string') {
    const context = title ? title.replace(/^Inside the /, '').replace(/^Photo Gallery: /, '') : '';
    const alt = context ? `${context} — View ${index + 1}` : `View ${index + 1}`;
    return { src: item, alt };
  }
  return item;
});

const itemCount = normalizedItems.length;
---

{itemCount > 0 && (
  <section class="gallery-section">
    {title && <h2 class="gallery-title">{title}</h2>}
    
    <div class={`gallery-masonry ${itemCount < 4 ? 'gallery-masonry--small' : ''}`}>
      {normalizedItems.map((item, i) => (
        <a
          href={item.src}
          class={`gallery-item reveal glightbox item-${i}`}
          data-gallery="gallery"
          data-glightbox="title: "
          aria-label={`View ${item.alt} in full screen`}
          style={`transition-delay: ${i * 0.05}s`}
        >
          <div class="gallery-thumb">
            <Picture
              src={item.src}
              alt={item.alt}
              loading="lazy"
              decoding="async"
              class="gallery-img"
            />

            {i === 3 && itemCount > 4 && (
              <div class="gallery-overlay-count mobile-only-count">
                <span>+{itemCount - 4}</span>
              </div>
            )}

            {i === 5 && itemCount > 6 && (
              <div class="gallery-overlay-count desktop-only-count">
                <span>+{itemCount - 6}</span>
              </div>
            )}

            <div class="gallery-overlay">
              <div class="overlay-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 3h6v6"/><path d="M9 21H3v-6"/><path d="M21 3l-7 7"/><path d="M3 21l7-7"/>
                </svg>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<script>
  import GLightbox from 'glightbox';

  let lightbox: any = null;

  function initGallery() {
    if (lightbox) {
      lightbox.destroy();
      lightbox = null;
    }
    lightbox = GLightbox({ selector: '.glightbox' });
  }

  initGallery();
  document.addEventListener('astro:page-load', initGallery);
</script>

<style>
  .gallery-section {
    margin-top: 5rem;
    padding: 0 1rem;
  }

  .gallery-title {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 2.5rem;
    color: var(--foreground);
    text-align: center;
  }

  /* Grid Layout - 3 columns on desktop, 2 columns on mobile */
  .gallery-masonry {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    width: 100%;
  }

  .gallery-masonry--small {
    grid-template-columns: repeat(2, 1fr);
  }

  @media (max-width: 768px) {
    .gallery-masonry {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.35rem;
    }
  }

  .gallery-item {
    display: block;
    width: 100%;
    border-radius: var(--radius-xl);
    overflow: hidden;
    cursor: zoom-in;
    transform: translateZ(0);
  }

  .gallery-thumb {
    width: 100%;
    aspect-ratio: 4 / 3;
    position: relative;
    overflow: hidden;
  }

  .gallery-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.2, 0, 0, 1);
  }

  .gallery-thumb :global(picture) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    overflow: hidden;
  }

  .gallery-thumb :global(picture img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gallery-item:hover .gallery-thumb :global(picture img) {
    transform: scale(1.05);
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .overlay-icon {
    width: 48px;
    height: 48px;
    background: rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transform: scale(0.8);
    transition: transform 0.4s cubic-bezier(0.2, 0, 0, 1);
  }

  .gallery-item:hover .gallery-overlay {
    opacity: 1;
  }

  .gallery-item:hover .overlay-icon {
    transform: scale(1);
  }
  
  /* GLightbox overrides */
  :global(.goverlay) {
    background: rgba(0, 0, 0, 0.95) !important;
    backdrop-filter: blur(10px);
  }

  /* Visibility based on index for Gallery grid */
  .gallery-item { display: none; }
  .gallery-item.item-0,
  .gallery-item.item-1,
  .gallery-item.item-2,
  .gallery-item.item-3 { display: block; }

  @media (min-width: 640px) {
    .gallery-item.item-4,
    .gallery-item.item-5 { display: block; }
  }

  /* Overlay count styling */
  .gallery-overlay-count {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.75rem;
    font-weight: 800;
    pointer-events: none;
    transition: background-color 0.3s ease;
    z-index: 5;
  }

  .gallery-item:hover .gallery-overlay-count {
    background: rgba(0, 0, 0, 0.4);
  }

  .mobile-only-count { display: flex; }
  .desktop-only-count { display: none; }

  @media (min-width: 640px) {
    .mobile-only-count { display: none; }
    .desktop-only-count { display: flex; }
  }
</style>
