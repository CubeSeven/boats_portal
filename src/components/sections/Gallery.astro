---
import 'glightbox/dist/css/glightbox.css';
import Picture from '../ui/Picture.astro';

interface GalleryItem {
  src: string;
  alt: string;
}

interface Props {
  items?: (GalleryItem | string)[];
  title?: string;
}

const {
  items = [],
  title,
} = Astro.props;

// Normalize items — generate descriptive alt text from title context
const normalizedItems: GalleryItem[] = items.map((item, index) => {
  if (typeof item === 'string') {
    const context = title ? title.replace(/^Inside the /, '').replace(/^Photo Gallery: /, '') : '';
    const alt = context ? `${context} — View ${index + 1}` : `View ${index + 1}`;
    return { src: item, alt };
  }
  return item;
});

const itemCount = normalizedItems.length;
---

{itemCount > 0 && (
  <section class="gallery-section">
    {title && <h2 class="gallery-title">{title}</h2>}
    
    <div class={`gallery-masonry ${itemCount < 4 ? 'gallery-masonry--small' : ''}`}>
      {normalizedItems.map((item, i) => (
        <a
          href={item.src}
          class="gallery-item reveal glightbox"
          data-gallery="gallery"
          data-glightbox="title: "
          aria-label={`View ${item.alt} in full screen`}
          style={`transition-delay: ${i * 0.05}s`}
        >
          <div class="gallery-thumb">
            <Picture 
              src={item.src} 
              alt={item.alt} 
              loading="lazy"
              decoding="async"
              class="gallery-img"
            />
            <div class="gallery-overlay">
              <div class="overlay-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 3h6v6"/><path d="M9 21H3v-6"/><path d="M21 3l-7 7"/><path d="M3 21l7-7"/>
                </svg>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<script>
  import GLightbox from 'glightbox';
  import type { GLightbox as GLightboxNS } from 'glightbox';

  let lightbox: GLightboxNS | null = null;

  function initGallery() {
    if (lightbox) {
      lightbox.destroy();
      lightbox = null;
    }
    lightbox = GLightbox({ selector: '.glightbox' });
  }

  initGallery();
  document.addEventListener('astro:page-load', initGallery);
</script>

<style>
  .gallery-section {
    margin-top: 5rem;
    padding: 0 1rem;
  }

  .gallery-title {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 2.5rem;
    color: var(--foreground);
    text-align: center;
  }

  /* Masonry Layout using CSS Columns */
  /* This ensures no holes regardless of item count */
  .gallery-masonry {
    column-count: 3;
    column-gap: 1rem;
    width: 100%;
  }

  .gallery-masonry--small {
    column-count: 2;
  }

  @media (max-width: 1024px) {
    .gallery-masonry { column-count: 2; }
  }

  @media (max-width: 640px) {
    .gallery-masonry { column-count: 1; }
  }

  .gallery-item {
    display: inline-block;
    width: 100%;
    margin-bottom: 1rem;
    border-radius: var(--radius-xl);
    overflow: hidden;
    cursor: zoom-in;
    transform: translateZ(0);
    break-inside: avoid; /* Prevents item from splitting between columns */
  }

  .gallery-thumb {
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .gallery-img {
    width: 100%;
    height: auto; /* Allow natural height for masonry */
    display: block;
    transition: transform 0.6s cubic-bezier(0.2, 0, 0, 1);
  }

  .gallery-item:hover .gallery-img {
    transform: scale(1.05);
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .overlay-icon {
    width: 48px;
    height: 48px;
    background: rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transform: scale(0.8);
    transition: transform 0.4s cubic-bezier(0.2, 0, 0, 1);
  }

  .gallery-item:hover .gallery-overlay {
    opacity: 1;
  }

  .gallery-item:hover .overlay-icon {
    transform: scale(1);
  }
  
  /* GLightbox overrides */
  :global(.goverlay) {
    background: rgba(0, 0, 0, 0.95) !important;
    backdrop-filter: blur(10px);
  }
</style>
