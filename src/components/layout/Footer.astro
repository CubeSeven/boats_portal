---
import { getSortedTours, getSortedLocations, getSiteSettings } from '../../lib/collections';
import DynamicIcon from '../ui/DynamicIcon.astro';

const site = await getSiteSettings();
const allTours = await getSortedTours();
const allLocations = await getSortedLocations();

const footerLinks = {
  services: [
    { label: 'Boat Rental', href: '/boat-rental/' },
    { label: 'No License Required', href: '/boat-rental/no-license-required/' },
    { label: 'With Skipper', href: '/boat-rental/with-skipper/' },
    { label: 'Luxury Yacht Charter', href: '/boat-rental/luxury-yacht-charter/' },
    { label: 'Transfer', href: '/transfers/' },
  ],
  tours: allTours
    .slice(0, 5)
    .map(t => ({ label: t.data.title.split('|')[0].trim(), href: `/private-boat-tours/${t.id}/` })),
  explore: [
    ...allLocations
      .slice(0, 3)
      .map(l => ({ label: l.data.locationName, href: `/locations/${l.id}/` })),
    { label: 'Travel Blog', href: '/blog/' },
    { label: 'Frequently Asked Questions', href: '/faqs/' },
  ],
};

const socials = [
  { label: 'Facebook', href: site?.socials?.facebook || '#', icon: 'facebook' },
  { label: 'Instagram', href: site?.socials?.instagram || '#', icon: 'instagram' },
  { label: 'TripAdvisor', href: site?.socials?.tripadvisor || '#', icon: 'tripadvisor' },
  { label: 'WhatsApp', href: site?.whatsapp ? `https://wa.me/${site.whatsapp.replace(/[^0-9]/g, '')}` : '#', icon: 'whatsapp' },
];
---

<footer class="mt-24" role="contentinfo">
  <!-- Wave decoration -->
  <div class="w-full h-20 overflow-hidden bg-background" aria-hidden="true">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full block">
      <path
        d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z"
        fill="var(--black)"
      />
    </svg>
  </div>

  <div class="bg-black text-white/70 pt-12 pb-0">
    <h2 class="sr-only">Site Navigation & Information</h2>
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1fr] gap-12 pb-12">
        <!-- Brand Column -->
        <div class="flex flex-col gap-5">
          <a href="/" class="flex items-center gap-2 no-underline text-white" aria-label="Sea Skiathos — Home">
            <img src="/sea_skiathos.svg" width="40" height="40" class="h-10 w-auto shrink-0 invert" alt="Sea Skiathos" />
            <span class="font-sans text-xl font-medium tracking-tight uppercase">Sea<strong class="font-black">Skiathos</strong></span>
          </a>
          <p class="text-xs leading-relaxed m-0 text-white/40 max-w-[300px] uppercase font-bold tracking-widest">
            Your premium sea experience partner in Skiathos. Explore the Aegean in style — rent a boat, join a tour, or let us take you there.
          </p>
          <div class="flex flex-col gap-3">
            {site?.phone && (
              <a href={`tel:${site.phone.replace(/ /g, '')}`} class="flex items-center gap-2 text-[0.85rem] text-white/60 no-underline transition-colors hover:text-white uppercase font-bold tracking-widest">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="opacity-40"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.63A2 2 0 0 1 3.54 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                {site.phone}
              </a>
            )}
            {site?.email && (
              <a href={`mailto:${site.email}`} class="flex items-center gap-2 text-[0.85rem] text-white/60 no-underline transition-colors hover:text-white uppercase font-bold tracking-widest">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="opacity-40"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                {site.email}
              </a>
            )}
          </div>
          <!-- Social Links -->
          <div class="flex gap-2 flex-wrap mt-4">
            {socials.map((s) => (
              <a href={s.href} aria-label={s.label} class="flex items-center justify-center w-10 h-10 rounded-full bg-white/5 text-white/50 no-underline transition-all hover:bg-white hover:text-black hover:-translate-y-1">
                <DynamicIcon name={s.icon} size={16} strokeWidth={2} />
              </a>
            ))}
          </div>
        </div>

        <!-- Services Column -->
        <div class="flex flex-col gap-4">
          <h3 class="font-sans text-[0.7rem] font-black tracking-widest uppercase text-white m-0 opacity-50">Boat Rental</h3>
          <ul role="list" class="list-none p-0 m-0 flex flex-col gap-2">
            {footerLinks.services.map((l) => (
              <li><a href={l.href} class="text-[0.75rem] font-bold tracking-widest uppercase text-white/40 no-underline transition-colors hover:text-white">{l.label}</a></li>
            ))}
          </ul>
        </div>

        <!-- Tours Column -->
        <div class="flex flex-col gap-4">
          <h3 class="font-sans text-[0.7rem] font-black tracking-widest uppercase text-white m-0 opacity-50">Private Tours</h3>
          <ul role="list" class="list-none p-0 m-0 flex flex-col gap-2">
            {footerLinks.tours.map((l) => (
              <li><a href={l.href} class="text-[0.75rem] font-bold tracking-widest uppercase text-white/40 no-underline transition-colors hover:text-white">{l.label}</a></li>
            ))}
          </ul>
        </div>

        <!-- Explore Column -->
        <div class="flex flex-col gap-4">
          <h3 class="font-sans text-[0.7rem] font-black tracking-widest uppercase text-white m-0 opacity-50">Explore</h3>
          <ul role="list" class="list-none p-0 m-0 flex flex-col gap-2">
            {footerLinks.explore.map((l) => (
              <li><a href={l.href} class="text-[0.75rem] font-bold tracking-widest uppercase text-white/40 no-underline transition-colors hover:text-white">{l.label}</a></li>
            ))}
          </ul>
          <div class="mt-6 pt-6 border-t border-white/5">
            <h4 class="font-sans text-[0.6rem] font-black tracking-widest uppercase text-white m-0 mb-2 opacity-30">Opening Hours</h4>
            <p class="text-[0.75rem] font-bold tracking-widest uppercase text-white/30 m-0 mb-1">Daily: 08:00 — 20:00</p>
            <p class="text-[0.75rem] font-bold tracking-widest uppercase text-white/30 m-0">Transfer: 24/7</p>
          </div>
        </div>
      </div>

      <!-- Bottom Bar -->
      <div class="border-t border-white/5 py-8 flex flex-col md:flex-row justify-between items-center gap-4 text-center md:text-left">
        <p class="text-[0.65rem] font-bold tracking-widest uppercase text-white/20 m-0 italic">&copy; {new Date().getFullYear()} {site?.seo?.siteName}. All rights reserved. Skiathos, Greece.</p>
        <div class="flex gap-8">
          <a href="/privacy/" class="text-[0.65rem] font-bold tracking-widest uppercase text-white/30 no-underline transition-colors hover:text-white">Privacy</a>
          <a href="/terms/" class="text-[0.65rem] font-bold tracking-widest uppercase text-white/30 no-underline transition-colors hover:text-white">Terms</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<!-- LocalBusiness schema is injected globally by Layout.astro -->
