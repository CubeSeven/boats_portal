---
// Fixed bottom bar — visible only on mobile
import { getSiteSettings } from '../../lib/collections';
const site = await getSiteSettings();
---

<div class="fixed bottom-2 left-2 right-2 z-[100] bg-black/80 backdrop-blur-xl border border-white/10 rounded-xl shadow-2xl md:hidden" id="mobile-cta-bar" role="complementary" aria-label="Quick booking actions">
  <div class="container flex items-center gap-2 px-5 py-2.5">
    {site?.phone && (
      <a href={`tel:${site.phone.replace(/ /g, '')}`} class="flex flex-col items-center gap-1 text-white opacity-60 no-underline text-[0.65rem] font-black uppercase tracking-widest px-3 py-2 rounded-md transition-all hover:opacity-100 hover:bg-white/10 shrink-0 min-w-[65px]" aria-label="Call us">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.63A2 2 0 0 1 3.54 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        <span>Call</span>
      </a>
    )}
    <a href={`https://wa.me/${site?.whatsapp.replace('+', '')}`} class="flex flex-col items-center gap-1 text-white opacity-60 no-underline text-[0.65rem] font-black uppercase tracking-widest px-3 py-2 rounded-sm transition-all hover:opacity-100 hover:bg-white/10 shrink-0 min-w-[65px]" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp us">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
      </svg>
      <span>WhatsApp</span>
    </a>
    <button onclick="window.__openBookingModal()" class="flex-1 flex items-center justify-center bg-white text-black font-black text-[0.85rem] uppercase tracking-widest rounded-md py-3 mb-0.5 h-12 transition-all hover:bg-neutral-100 hover:-translate-y-1 active:translate-y-0 shadow-lg italic border-none cursor-pointer">
      Book Now
    </button>
  </div>
</div>
