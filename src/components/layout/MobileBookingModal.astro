---
import { getFleet, getSortedTours, getSortedServices, getSiteSettings } from '../../lib/collections';
import { getCollection } from 'astro:content';
import BoatCard from '../cards/BoatCard.astro';
import TourCard from '../cards/TourCard.astro';

const fleet = await getFleet();
const tours = await getSortedTours();
const services = await getSortedServices();
const routes = await getCollection('routes');
const activities = await getCollection('activities');
const site = await getSiteSettings();

const emailTo = site?.email || 'info@skiathosboats.com';
const waNumber = (site?.whatsapp || '').replace(/[^0-9]/g, '');

const servicesJSON = JSON.stringify(
  services.map(s => ({
    id: s.id,
    title: s.data.title,
    description: s.data.description,
    icon: s.data.icon,
    price: s.data.price,
  }))
);

const routesJSON = JSON.stringify(
  routes.sort((a: any, b: any) => (a.data.order ?? 99) - (b.data.order ?? 99)).map(r => ({
    id: r.id,
    title: r.data.title,
    fromLocation: r.data.fromLocation,
    toLocation: r.data.toLocation,
    duration: r.data.duration,
    priceFrom: (r.data.pricing?.[0] as any)?.price || '',
  }))
);

const watersportsFiltered = activities
  .filter((a: any) => a.data.category === 'watersports')
  .sort((a: any, b: any) => (a.data.order ?? 99) - (b.data.order ?? 99));

const watersportsJSON = JSON.stringify(
  watersportsFiltered.map(a => ({
    id: a.id,
    title: a.data.title,
    description: a.data.description,
    price: a.data.price,
  }))
);

const FLEET_TYPES = ['no-license', 'with-license', 'rib', 'yacht'];
const FLEET_CHIP_LABELS: Record<string, string> = {
  'no-license': 'No License',
  'with-license': 'License Req',
  'rib': 'RIB',
  'yacht': 'Yacht',
};
---

<div id="booking-modal" class="modal-root" hidden>
  <div class="modal-backdrop"></div>

  <div class="modal-sheet">
    <!-- Header -->
    <div class="modal-header">
      <button class="modal-back-btn hidden" aria-label="Back">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
        </svg>
      </button>
      <h2 class="modal-title">Book Now</h2>
      <button class="modal-close-btn" aria-label="Close">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <!-- Progress dots -->
    <div class="modal-progress">
      <span class="progress-dot" data-step="1"></span>
      <span class="progress-dot" data-step="2"></span>
      <span class="progress-dot" data-step="3"></span>
      <span class="progress-dot" data-step="4"></span>
    </div>

    <!-- Body -->
    <div class="modal-body"></div>
  </div>
</div>

<!-- Hidden card pool — rendered server-side with real components, moved into modal by JS -->
<div id="modal-card-pool" aria-hidden="true" style="display:none">
  <!-- Boats by type -->
  {FLEET_TYPES.map(type => (
    <div data-pool="boat-rental" data-pool-type={type}>
      {fleet.filter(b => b.data.type === type).map(boat => (
        <div class="select-card-wrap" data-sub-id={boat.id} data-sub-name={boat.data.name}>
          <BoatCard
            name={boat.data.name}
            type={boat.data.type}
            priceFrom={boat.data.priceFrom}
            priceHalfDay={boat.data.priceHalfDay}
            priceFullDay={boat.data.priceFullDay}
            slug={boat.id}
            specs={[
              { label: 'Length', value: boat.data.length },
              { label: 'Capacity', value: `${boat.data.capacity} pers.` },
              { label: 'Engine', value: `${boat.data.horsepower} HP` },
            ]}
            image={boat.data.image}
            features={boat.data.features}
          />
        </div>
      ))}
    </div>
  ))}

  <!-- Custom boat request -->
  <div data-pool="boat-rental" data-pool-type="custom">
    <div class="select-card-wrap" data-sub-id="custom-boat" data-sub-name="Custom Boat Request">
      <div class="card group h-full">
        <div class="card-content">
          <div class="card-image-wrap flex items-center justify-center bg-muted">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3"><path d="M12 5v14M5 12h14"/></svg>
          </div>
          <div class="flex flex-col flex-1 p-5">
            <header class="card-header">
              <div class="min-w-0">
                <span class="boat-type-label">Custom</span>
                <h3 class="boat-name">Custom Boat Request</h3>
              </div>
            </header>
            <p class="card-desc">Need a different boat, skippered vessel, or multi-day rental? Tell us what you need.</p>
            <div class="card-footer mt-auto">
              <div class="price-block">
                <span class="price-value" style="font-size:0.85rem;">On Request</span>
              </div>
              <span class="btn-primary-pill label-only">Select →</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Tours -->
  <div data-pool="private-tours">
    {tours.map(t => (
      <div class="select-card-wrap" data-sub-id={t.id} data-sub-name={t.data.title}>
        <div class="relative pointer-events-none">
          <TourCard
            title={t.data.title}
            description={t.data.description}
            href={`/private-boat-tours/${t.id}/`}
            price={t.data.pricing?.[0]?.price ? `€${t.data.pricing[0].price}` : undefined}
            image={t.data.image}
            badge={t.data.duration}
            buttonText="Select"
          />
        </div>
      </div>
    ))}

    <!-- Custom tour -->
    <div class="select-card-wrap" data-sub-id="custom-tour" data-sub-name="Custom Private Tour">
      <div class="card group h-full">
        <div class="card-content">
          <div class="card-image-wrap flex items-center justify-center bg-muted">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3"><path d="M12 5v14M5 12h14"/></svg>
          </div>
          <div class="flex flex-col flex-1 p-5">
            <header class="card-header">
              <div class="min-w-0">
                <span class="boat-type-label">Custom</span>
                <h3 class="boat-name">Custom Private Tour</h3>
              </div>
            </header>
            <p class="card-desc">Design a custom day itinerary around Skiathos, Skopelos, or Alonissos.</p>
            <div class="card-footer mt-auto">
              <div class="price-block">
                <span class="price-value" style="font-size:0.85rem;">On Request</span>
              </div>
              <span class="btn-primary-pill label-only">Select →</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Routes / Transfers -->
  <div data-pool="transfers">
    {routes.map(r => (
      <div class="select-card-wrap" data-sub-id={r.id} data-sub-name={`${r.data.fromLocation} → ${r.data.toLocation}`}>
        <div class="card group h-full">
          <div class="card-content">
            <div class="flex flex-col flex-1 p-5">
              <header class="card-header">
                <div class="min-w-0">
                  <span class="boat-type-label">Transfer</span>
                  <h3 class="boat-name">{r.data.fromLocation} → {r.data.toLocation}</h3>
                </div>
              </header>
              <p class="card-desc">Private sea taxi transfer. {r.data.duration || ''}</p>
              <div class="card-footer mt-auto">
                <div class="price-block">
                  <span class="price-value">{r.data.pricing?.[0]?.price || ''}</span>
                </div>
                <span class="btn-primary-pill label-only">Select →</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    ))}

    <div class="select-card-wrap" data-sub-id="custom-route" data-sub-name="Custom Transfer">
      <div class="card group h-full">
        <div class="card-content">
          <div class="flex flex-col flex-1 p-5">
            <header class="card-header">
              <div class="min-w-0">
                <span class="boat-type-label">Custom</span>
                <h3 class="boat-name">Custom Transfer</h3>
              </div>
            </header>
            <p class="card-desc">Need a transfer between specific coves, beaches, or nearby islands?</p>
            <div class="card-footer mt-auto">
              <div class="price-block">
                <span class="price-value" style="font-size:0.85rem;">On Request</span>
              </div>
              <span class="btn-primary-pill label-only">Select →</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Watersports -->
  <div data-pool="watersports">
    {watersportsFiltered.map(w => (
      <div class="select-card-wrap" data-sub-id={w.id} data-sub-name={w.data.title}>
        <div class="card group h-full">
          <div class="card-content">
            <div class="flex flex-col flex-1 p-5">
              <header class="card-header">
                <div class="min-w-0">
                  <span class="boat-type-label">Watersports</span>
                  <h3 class="boat-name">{w.data.title}</h3>
                </div>
              </header>
              <p class="card-desc">{w.data.description}</p>
              <div class="card-footer mt-auto">
                <div class="price-block">
                  <span class="price-label">Price</span>
                  <span class="price-value" style="font-size:1rem;">{w.data.price}</span>
                </div>
                <span class="btn-primary-pill label-only">Select →</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    ))}

    <div class="select-card-wrap" data-sub-id="custom-watersports" data-sub-name="Custom Watersports Package">
      <div class="card group h-full">
        <div class="card-content">
          <div class="flex flex-col flex-1 p-5">
            <header class="card-header">
              <div class="min-w-0">
                <span class="boat-type-label">Custom</span>
                <h3 class="boat-name">Custom Watersports / Mixed Package</h3>
              </div>
            </header>
            <p class="card-desc">Mix multiple toys, add extra time, or request group packages.</p>
            <div class="card-footer mt-auto">
              <div class="price-block">
                <span class="price-value" style="font-size:0.85rem;">On Request</span>
              </div>
              <span class="btn-primary-pill label-only">Select →</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style is:global>
  @reference "../../styles/global.css";

  /* ── Modal Root ────────────────────────────── */
  #booking-modal.modal-root {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  #booking-modal .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  #booking-modal.modal-root.open .modal-backdrop { opacity: 1; }

  #booking-modal .modal-sheet {
    position: relative;
    width: 100%;
    max-width: 720px;
    background: var(--background);
    border-top-left-radius: var(--radius-xl);
    border-top-right-radius: var(--radius-xl);
    border: 1px solid var(--border);
    border-bottom: none;
    box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.15);
    display: flex;
    flex-direction: column;
    max-height: 90vh;
    z-index: 10;
    transform: translateY(100%);
    transition: transform 0.3s var(--ease-premium, ease);
  }

  #booking-modal.modal-root.open .modal-sheet {
    transform: translateY(0);
  }

  @media (min-width: 768px) {
    #booking-modal.modal-root {
      align-items: center;
      padding: 2rem;
    }
    #booking-modal .modal-sheet {
      border-radius: var(--radius-xl);
      max-height: 85vh;
      border-bottom: 1px solid var(--border);
      transform: translateY(20px);
      opacity: 0;
      transition: transform 0.3s var(--ease-premium, ease), opacity 0.3s;
    }
    #booking-modal.modal-root.open .modal-sheet {
      transform: translateY(0);
      opacity: 1;
    }
  }

  #booking-modal .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  #booking-modal .modal-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin: 0;
    flex: 1;
    text-align: center;
  }

  #booking-modal .modal-back-btn,
  #booking-modal .modal-close-btn {
    background: none;
    border: none;
    padding: 0.5rem;
    cursor: pointer;
    color: var(--muted-foreground);
    display: flex;
    border-radius: 999px;
    transition: background 0.15s, color 0.15s;
  }

  #booking-modal .modal-back-btn:hover,
  #booking-modal .modal-close-btn:hover {
    background: var(--muted);
    color: var(--foreground);
  }

  #booking-modal .modal-back-btn.hidden { opacity: 0; pointer-events: none; }

  #booking-modal .modal-progress {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem 0.5rem;
  }

  #booking-modal .progress-dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--border);
    transition: all 0.3s ease;
  }

  #booking-modal .progress-dot.active { width: 24px; background: var(--foreground); }
  #booking-modal .progress-dot.done { background: var(--muted-foreground); }

  #booking-modal .modal-body {
    flex: 1;
    overflow-y: auto;
    padding: 0.5rem 1.5rem 2rem;
  }

  /* ── Step 1: Services ─────────────────────── */
  #booking-modal .step-services {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  @media (min-width: 480px) {
    #booking-modal .step-services {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  #booking-modal .service-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-2xl);
    background: var(--card);
    cursor: pointer;
    transition: all 0.15s;
    gap: 0.75rem;
    text-align: center;
  }

  #booking-modal .service-card:hover {
    border-color: var(--foreground);
    background: var(--muted)/30;
  }

  #booking-modal .service-card.selected {
    border-color: var(--foreground);
  }

  #booking-modal .service-card-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 400;
  }

  #booking-modal .service-card-price {
    font-size: 0.75rem;
    color: var(--muted-foreground);
  }

  /* ── Step 2: Cards grid ───────────────────── */
  #booking-modal .step2-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 600px) {
    #booking-modal .step2-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  #booking-modal .select-card-wrap {
    cursor: pointer;
    /* The select-card-wrap IS the click target. Card inside gets pointer-events:none */
    position: relative;
  }

  #booking-modal .select-card-wrap.selected {
    outline: 3px solid var(--foreground);
    outline-offset: 2px;
    border-radius: var(--radius-2xl);
  }

  /* Card inside wrapper should never capture clicks directly */
  #booking-modal .select-card-wrap .group,
  #booking-modal .select-card-wrap .card,
  #booking-modal .select-card-wrap article,
  #booking-modal .select-card-wrap a {
    pointer-events: none !important;
  }

  #booking-modal .card-desc {
    font-size: 0.78rem;
    color: var(--muted-foreground);
    line-height: 1.35;
    margin: 0.5rem 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  #booking-modal .btn-primary-pill.label-only {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    background: var(--foreground);
    color: var(--background);
    border: 1px solid var(--foreground);
  }

  /* ── Chips ────────────────────────────────── */
  #booking-modal .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 0.75rem;
  }

  #booking-modal .chip {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--card);
    color: var(--muted-foreground);
    cursor: pointer;
    transition: all 0.15s;
  }

  #booking-modal .chip:hover,
  #booking-modal .chip.active {
    border-color: var(--foreground);
    color: var(--foreground);
  }

  #booking-modal .chip.active { background: var(--muted); }

  /* ── Step 3: Details Form ─────────────────── */
  #booking-modal .step-form { display: flex; flex-direction: column; gap: 1rem; }

  #booking-modal .summary {
    font-size: 0.82rem;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-lg);
    background: var(--muted)/40;
    color: var(--muted-foreground);
    line-height: 1.4;
  }

  #booking-modal .summary strong { color: var(--foreground); }

  #booking-modal .form-row-2 {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 480px) {
    #booking-modal .form-row-2 {
      grid-template-columns: 1fr 1fr;
    }
  }

  #booking-modal .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  #booking-modal .form-field label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted-foreground);
  }

  #booking-modal .form-field input,
  #booking-modal .form-field textarea {
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--background);
    font-size: 0.85rem;
    color: var(--foreground);
    transition: border-color 0.15s;
    width: 100%;
    box-sizing: border-box;
  }

  #booking-modal .form-field input:focus,
  #booking-modal .form-field textarea:focus {
    border-color: var(--foreground);
    outline: none;
  }

  #booking-modal .step3-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  #booking-modal .submit-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 1rem;
    background: var(--foreground);
    color: var(--background);
    border: none;
    border-radius: 999px;
    font-size: 0.88rem;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  #booking-modal .submit-btn:hover { opacity: 0.9; }

  #booking-modal .outline-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.85rem;
    border: 1.5px solid var(--border);
    border-radius: 999px;
    background: transparent;
    color: var(--muted-foreground);
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }

  #booking-modal .outline-btn:hover {
    border-color: var(--foreground);
    color: var(--foreground);
  }

  /* ── Step 4: Add-ons ──────────────────────── */
  #booking-modal .step-addons { display: flex; flex-direction: column; gap: 1rem; }

  #booking-modal .addon-card {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.85rem;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--card);
    cursor: pointer;
    transition: border-color 0.15s;
  }

  #booking-modal .addon-card:hover { border-color: var(--foreground); }

  #booking-modal .addon-card input[type="checkbox"] {
    margin-top: 0.2rem;
    accent-color: var(--foreground);
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  #booking-modal .addon-card-content { display: flex; flex-direction: column; gap: 0.15rem; }

  #booking-modal .addon-card-name {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 700;
  }

  #booking-modal .addon-card-desc {
    font-size: 0.7rem;
    color: var(--muted-foreground);
    line-height: 1.3;
  }

  #booking-modal .addon-select-wrap {
    margin: -0.25rem 0 0.75rem 1.8rem;
  }

  #booking-modal .form-select {
    width: 100%;
    padding: 0.6rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--background);
    font-size: 0.78rem;
    color: var(--foreground);
  }

  #booking-modal .form-section-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted-foreground);
    display: block;
  }

  #booking-modal .addon-custom-field label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted-foreground);
    display: block;
    margin-bottom: 0.25rem;
  }

  #booking-modal .addon-custom-field textarea {
    width: 100%;
    min-height: 60px;
    padding: 0.6rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--background);
    font-size: 0.78rem;
    color: var(--foreground);
    resize: vertical;
  }

  #booking-modal .addons-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  /* ── Result Panel ─────────────────────────── */
  #booking-modal .result-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem 1rem;
    gap: 1rem;
  }

  #booking-modal .result-panel-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 400;
  }

  #booking-modal .result-panel-desc {
    font-size: 0.85rem;
    color: var(--muted-foreground);
    max-width: 280px;
    line-height: 1.4;
  }

  #booking-modal .result-actions {
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 0.75rem;
    max-width: 320px;
    margin-top: 0.5rem;
  }

  #booking-modal .result-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.85rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  #booking-modal .result-btn:hover { opacity: 0.9; }

  #booking-modal .result-btn.whatsapp { background: #25d366; color: white; }
  #booking-modal .result-btn.email { background: var(--foreground); color: var(--background); }

  /* FIX: Ensure cards using .reveal class in the modal are always fully visible */
  #booking-modal .reveal {
    opacity: 1 !important;
    transform: none !important;
    transition: none !important;
    visibility: visible !important;
  }
</style>

<script define:vars={{
  servicesRaw: servicesJSON,
  routesRaw: routesJSON,
  wspRaw: watersportsJSON,
  emailToVal: emailTo,
  waNumberVal: waNumber,
}}>
(function () {
  const SERVICES = JSON.parse(servicesRaw);
  const ROUTES = JSON.parse(routesRaw);
  const WSPORTS = JSON.parse(wspRaw);
  const EMAIL_TO = emailToVal;
  const WA_NUMBER = waNumberVal;

  let step = 1;
  let selectedServiceId = null;
  let selectedSubOptionId = null;
  let selectedSubOptionName = '';
  let activeBoatType = 'no-license';

  // Add-on state
  let addSkipper = false;
  let selectedWatersports = [];
  let customExtrasText = '';

  // Pre-fill fields
  let prefilledDate = '';
  let prefilledGuests = '';
  let prefilledName = '';
  let prefilledEmail = '';

  const modal = document.getElementById('booking-modal');
  const body = modal.querySelector('.modal-body');
  const backBtn = modal.querySelector('.modal-back-btn');
  const closeBtn = modal.querySelector('.modal-close-btn');
  const titleEl = modal.querySelector('.modal-title');
  const backdrop = modal.querySelector('.modal-backdrop');
  const dots = modal.querySelectorAll('.progress-dot');
  const pool = document.getElementById('modal-card-pool');

  function updateProgress(s) {
    dots.forEach(d => {
      const ds = parseInt(d.dataset.step || '0');
      d.classList.remove('active', 'done');
      if (ds === s) d.classList.add('active');
      if (ds < s) d.classList.add('done');
    });
  }

  function updateHeader(s) {
    const titles = { 1: 'Book Now', 2: 'Select Option', 3: 'Your Details', 4: 'Optional Extras' };
    titleEl.textContent = titles[s] || 'Book Now';
    backBtn.classList.toggle('hidden', s === 1);
  }

  function scrollBodyTop() { body.scrollTop = 0; }

  // ── Step 1: Services ────────────────────────────────

  function renderStep1() {
    let html = '<div class="step-services">';
    SERVICES.forEach(s => {
      html += `
        <button class="service-card${selectedServiceId === s.id ? ' selected' : ''}" data-service-id="${s.id}" type="button">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="${s.icon}"/>
          </svg>
          <span class="service-card-title">${s.title}</span>
          <span class="service-card-price">${s.price}</span>
        </button>`;
    });

    html += `
      <button class="service-card${selectedServiceId === 'custom' ? ' selected' : ''}" data-service-id="custom" type="button">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        <span class="service-card-title">Custom Request</span>
        <span class="service-card-price">Tailored Quote</span>
      </button>`;

    html += '</div>';
    body.innerHTML = html;

    body.querySelectorAll('.service-card').forEach(card => {
      card.addEventListener('click', () => {
        const id = card.dataset.serviceId;
        if (!id) return;
        selectedServiceId = id;
        if (id === 'custom') {
          selectedSubOptionId = 'custom';
          selectedSubOptionName = 'Custom Request';
          goToStep(3);
        } else {
          activeBoatType = 'no-license';
          goToStep(2);
        }
      });
    });
  }

  // ── Step 2: Cards from pool ─────────────────────────

  function renderStep2() {
    if (!selectedServiceId) { goToStep(1); return; }

    let html = '';

    // Boat chips
    if (selectedServiceId === 'boat-rental') {
      html += '<div class="chip-row">';
      const typeCounts = {};
      ['no-license', 'with-license', 'rib', 'yacht'].forEach(t => {
        typeCounts[t] = pool.querySelector(`[data-pool="boat-rental"][data-pool-type="${t}"]`)?.children.length || 0;
      });
      [['no-license', 'No License'], ['with-license', 'License Req'], ['rib', 'RIB'], ['yacht', 'Yacht']].forEach(([type, label]) => {
        html += `<button class="chip${type === activeBoatType ? ' active' : ''}" data-chip-type="${type}">${label} (${typeCounts[type]})</button>`;
      });
      html += '</div>';
    }

    html += '<div class="step2-cards"></div>';
    body.innerHTML = html;

    const grid = body.querySelector('.step2-cards');
    renderCardsIntoGrid(grid);

    // Bind chip clicks
    body.querySelectorAll('.chip').forEach(btn => {
      btn.addEventListener('click', () => {
        activeBoatType = btn.dataset.chipType;
        // Re-render cards for new filter
        const g = body.querySelector('.step2-cards');
        g.innerHTML = '';
        renderCardsIntoGrid(g);
        // Update chip active state
        body.querySelectorAll('.chip').forEach(c => c.classList.toggle('active', c.dataset.chipType === activeBoatType));
      });
    });

    // Bind card selection (delegation)
    grid.addEventListener('click', (e) => {
      const wrap = e.target.closest('.select-card-wrap');
      if (!wrap) return;
      const id = wrap.dataset.subId;
      const name = wrap.dataset.subName;
      if (!id || !name) return;
      selectedSubOptionId = id;
      selectedSubOptionName = name;
      goToStep(3);
    });

    scrollBodyTop();
  }

  function renderCardsIntoGrid(grid) {
    let poolGroup;
    if (selectedServiceId === 'boat-rental') {
      poolGroup = pool.querySelector(`[data-pool="boat-rental"][data-pool-type="${activeBoatType}"]`);
      if (!poolGroup) {
        // Fallback if no boat type data
        poolGroup = pool.querySelector(`[data-pool="boat-rental"][data-pool-type="no-license"]`);
      }
    } else {
      poolGroup = pool.querySelector(`[data-pool="${selectedServiceId}"]`);
    }

    if (!poolGroup) return;

    const clones = [];
    poolGroup.querySelectorAll(':scope > .select-card-wrap').forEach(w => {
      const clone = w.cloneNode(true);
      if (selectedSubOptionId && clone.dataset.subId === selectedSubOptionId) {
        clone.classList.add('selected');
      }
      clones.push(clone);
    });

    clones.forEach(c => grid.appendChild(c));
  }

  // ── Step 3: Details Form ────────────────────────────

  function renderStep3() {
    const serviceName = SERVICES.find(s => s.id === selectedServiceId)?.title || 'Service';

    let html = `
      <div class="step-form">
        <div class="summary">Selected: <strong>${serviceName}</strong> · ${selectedSubOptionName}</div>

        <form id="booking-details-form" class="step-form">
          <div class="form-row-2">
            <div class="form-field">
              <label for="bf-date">Date</label>
              <input type="date" id="bf-date" name="date" value="${prefilledDate}" required />
            </div>
            <div class="form-field">
              <label for="bf-guests">Guests</label>
              <input type="number" id="bf-guests" name="guests" min="1" max="30" value="${prefilledGuests}" placeholder="e.g. 4" />
            </div>
          </div>

          <div class="form-row-2">
            <div class="form-field">
              <label for="bf-name">Your Name</label>
              <input type="text" id="bf-name" name="name" value="${prefilledName}" placeholder="Full name" required />
            </div>
            <div class="form-field">
              <label for="bf-email">Email</label>
              <input type="email" id="bf-email" name="email" value="${prefilledEmail}" placeholder="you@example.com" required />
            </div>
          </div>

          <div class="form-field">
            <label for="bf-phone">Phone Number (WhatsApp preferred)</label>
            <input type="tel" id="bf-phone" name="phone" placeholder="e.g. +30 690..." required />
          </div>

          <div class="form-field">
            <label for="bf-notes">Special Requests & Extras</label>
            <textarea id="bf-notes" name="notes" rows="3" placeholder="Champagne, drinks, towels, snorkeling gear, custom routing requests...">${customExtrasText}</textarea>
          </div>

          <div class="step3-actions">
            <button type="button" class="outline-btn" id="go-addon-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Add Optional Extras
            </button>
            <button type="submit" class="submit-btn">Send Request →</button>
          </div>
        </form>

        <!-- Result panel -->
        <div class="result-panel" id="booking-result" hidden>
          <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          <span class="result-panel-title">Request Ready</span>
          <span class="result-panel-desc">Send your booking via:</span>
          <div class="result-actions">
            <a class="result-btn whatsapp" href="" target="_blank" rel="noopener noreferrer">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
              WhatsApp
            </a>
            <a class="result-btn email" href="">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
              Email
            </a>
          </div>
          <button class="submit-btn" type="button" id="booking-edit" style="background:var(--muted);color:var(--foreground);margin-top:0;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><polyline points="12 19 5 12 12 5"/></svg>
            Edit Request
          </button>
        </div>
      </div>`;

    body.innerHTML = html;
    bindStep3Events(serviceName);
    scrollBodyTop();
  }

  function bindStep3Events(serviceName) {
    const detailsForm = body.querySelector('#booking-details-form');
    const resultPanel = body.querySelector('#booking-result');
    const editBtn = body.querySelector('#booking-edit');
    const goAddonBtn = body.querySelector('#go-addon-btn');
    const notesInput = body.querySelector('#bf-notes');

    if (goAddonBtn) {
      goAddonBtn.addEventListener('click', () => {
        if (detailsForm) {
          const fd = new FormData(detailsForm);
          prefilledDate = fd.get('date') || '';
          prefilledGuests = fd.get('guests') || '';
          prefilledName = fd.get('name') || '';
          prefilledEmail = fd.get('email') || '';
        }
        goToStep(4);
      });
    }

    if (notesInput) {
      notesInput.addEventListener('input', () => { customExtrasText = notesInput.value; });
    }

    detailsForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const fd = new FormData(detailsForm);
      const date = fd.get('date') || '';
      const guests = fd.get('guests') || 'Not specified';
      const name = fd.get('name') || '';
      const email = fd.get('email') || '';
      const phone = fd.get('phone') || '';
      const notes = fd.get('notes') || '';

      prefilledDate = date;
      prefilledGuests = guests;
      prefilledName = name;
      prefilledEmail = email;

      let msg = `New Booking Request\n`;
      msg += `───────────────────\n`;
      msg += `Service: ${serviceName}\n`;
      msg += `Option: ${selectedSubOptionName}\n`;
      msg += `Date: ${date}\n`;
      msg += `Guests: ${guests}\n`;

      let addonsText = '';
      if (addSkipper) addonsText += `• Professional Skipper Upgrade (+€150/day)\n`;
      selectedWatersports.forEach(id => {
        const w = WSPORTS.find(x => x.id === id);
        if (w) addonsText += `• Watersports Add-on: ${w.title} (${w.price})\n`;
      });
      if (customExtrasText.trim()) addonsText += `• Special Requests: ${customExtrasText.trim()}\n`;
      if (addonsText) msg += `\nAdd-ons & Customizations:\n${addonsText}`;
      msg += `\nContact Details:\n`;
      msg += `• Name: ${name}\n`;
      msg += `• Email: ${email}\n`;
      msg += `• Phone: ${phone}\n`;
      if (notes.trim()) msg += `• Notes: ${notes.trim()}\n`;

      const encoded = encodeURIComponent(msg);
      const wa = body.querySelector('.result-btn.whatsapp');
      const em = body.querySelector('.result-btn.email');
      if (wa) wa.href = `https://wa.me/${WA_NUMBER}?text=${encoded}`;
      if (em) em.href = `mailto:${EMAIL_TO}?subject=Booking%20Request%20-%20${encodeURIComponent(name)}&body=${encoded}`;

      detailsForm.hidden = true;
      resultPanel.hidden = false;
    });

    if (editBtn) {
      editBtn.addEventListener('click', () => {
        resultPanel.hidden = true;
        detailsForm.hidden = false;
      });
    }
  }

  // ── Step 4: Optional Extras ─────────────────────────

  function renderStep4() {
    const serviceName = SERVICES.find(s => s.id === selectedServiceId)?.title || 'Service';

    let html = `
      <div class="step-addons">
        <div class="summary"><strong>${serviceName}</strong> · ${selectedSubOptionName}</div>
        <span class="form-section-title">Optional Extras</span>`;

    // Skipper for boat rental
    if (selectedServiceId === 'boat-rental') {
      html += `
        <label class="addon-card">
          <input type="checkbox" id="addon-skipper-check" ${addSkipper ? 'checked' : ''} />
          <div class="addon-card-content">
            <span class="addon-card-name">Professional Skipper (+€150/day)</span>
            <span class="addon-card-desc">Add a licensed captain to navigate and drive the boat for you</span>
          </div>
        </label>`;
    }

    // Watersports cross-sell
    if (selectedServiceId !== 'watersports') {
      html += `
        <label class="addon-card">
          <input type="checkbox" id="addon-wsp-check" ${selectedWatersports.length > 0 ? 'checked' : ''} />
          <div class="addon-card-content">
            <span class="addon-card-name">Add Watersports Activity</span>
            <span class="addon-card-desc">Add a Jet Ski, SUP, wakeboard or other activity to your booking</span>
          </div>
        </label>
        <div id="addon-wsp-select-wrap" class="addon-select-wrap" style="${selectedWatersports.length > 0 ? '' : 'display:none;'}">
          <select id="addon-wsp-select" class="form-select">
            <option value="">Choose activity...</option>
            ${WSPORTS.map(w => `<option value="${w.id}" ${selectedWatersports.includes(w.id) ? 'selected' : ''}>${w.title} (${w.price})</option>`).join('')}
          </select>
        </div>`;
    }

    html += `
      <div class="addon-custom-field">
        <label for="bf-custom-extras">Special Requests & Extras</label>
        <textarea id="bf-custom-extras" placeholder="Champagne, drinks, towels, snorkeling gear, custom routing requests...">${customExtrasText}</textarea>
      </div>

      <div class="addons-actions">
        <button type="button" class="outline-btn" id="back-to-details">← Back to Details</button>
        <button type="button" class="submit-btn" id="submit-from-addons">Send Request</button>
      </div>
    </div>`;

    body.innerHTML = html;
    bindStep4Events(serviceName);
    scrollBodyTop();
  }

  function bindStep4Events(serviceName) {
    const skipperCheck = body.querySelector('#addon-skipper-check');
    const wspCheck = body.querySelector('#addon-wsp-check');
    const wspSelectWrap = body.querySelector('#addon-wsp-select-wrap');
    const wspSelect = body.querySelector('#addon-wsp-select');
    const customExtrasInput = body.querySelector('#bf-custom-extras');
    const backBtn = body.querySelector('#back-to-details');
    const submitBtn = body.querySelector('#submit-from-addons');

    if (skipperCheck) {
      skipperCheck.addEventListener('change', () => { addSkipper = skipperCheck.checked; });
    }

    if (wspCheck) {
      wspCheck.addEventListener('change', () => {
        if (wspCheck.checked) {
          wspSelectWrap.style.display = 'block';
        } else {
          wspSelectWrap.style.display = 'none';
          selectedWatersports = [];
          if (wspSelect) wspSelect.value = '';
        }
      });
    }

    if (wspSelect) {
      wspSelect.addEventListener('change', () => {
        selectedWatersports = wspSelect.value ? [wspSelect.value] : [];
      });
    }

    if (customExtrasInput) {
      customExtrasInput.addEventListener('input', () => { customExtrasText = customExtrasInput.value; });
    }

    if (backBtn) {
      backBtn.addEventListener('click', () => goToStep(3));
    }

    if (submitBtn) {
      submitBtn.addEventListener('click', () => {
        const date = prefilledDate || 'Not specified';
        const guests = prefilledGuests || 'Not specified';
        const name = prefilledName || 'Guest';
        const email = prefilledEmail || '';
        const phone = body.querySelector('#bf-phone')?.value || '';

        let msg = `New Booking Request\n`;
        msg += `───────────────────\n`;
        msg += `Service: ${serviceName}\n`;
        msg += `Option: ${selectedSubOptionName}\n`;
        msg += `Date: ${date}\n`;
        msg += `Guests: ${guests}\n`;

        let addonsText = '';
        if (addSkipper) addonsText += `• Professional Skipper Upgrade (+€150/day)\n`;
        selectedWatersports.forEach(id => {
          const w = WSPORTS.find(x => x.id === id);
          if (w) addonsText += `• Watersports Add-on: ${w.title} (${w.price})\n`;
        });
        if (customExtrasText.trim()) addonsText += `• Special Requests: ${customExtrasText.trim()}\n`;
        if (addonsText) msg += `\nAdd-ons & Customizations:\n${addonsText}`;
        msg += `\nContact Details:\n`;
        msg += `• Name: ${name}\n`;
        msg += `• Email: ${email}\n`;
        msg += `• Phone: ${phone}\n`;

        const encoded = encodeURIComponent(msg);

        body.innerHTML = `
          <div class="step-form">
            <div class="result-panel" id="booking-result">
              <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
              <span class="result-panel-title">Request Ready</span>
              <span class="result-panel-desc">Send your booking via:</span>
              <div class="result-actions">
                <a class="result-btn whatsapp" href="https://wa.me/${WA_NUMBER}?text=${encoded}" target="_blank" rel="noopener noreferrer">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
                  WhatsApp
                </a>
                <a class="result-btn email" href="mailto:${EMAIL_TO}?subject=Booking%20Request%20-%20${encodeURIComponent(name)}&body=${encoded}">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
                  Email
                </a>
              </div>
              <button class="submit-btn" type="button" id="booking-edit" style="background:var(--muted);color:var(--foreground);margin-top:0;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><polyline points="12 19 5 12 12 5"/></svg>
                Edit Request
              </button>
            </div>
          </div>`;
      });
    }
  }

  // ── Navigation ─────────────────────────────────────

  function goToStep(s) {
    step = s;
    updateProgress(s);
    updateHeader(s);
    if (s === 1) renderStep1();
    else if (s === 2) renderStep2();
    else if (s === 3) renderStep3();
    else if (s === 4) renderStep4();
    scrollBodyTop();
  }

  function open(options = {}) {
    document.body.style.overflow = 'hidden';
    modal.hidden = false;

    selectedServiceId = options.serviceId || null;
    selectedSubOptionId = options.subId || null;
    selectedSubOptionName = options.subName || '';
    prefilledDate = options.date || '';
    prefilledGuests = options.guests || '';
    prefilledName = options.name || '';
    prefilledEmail = options.email || '';

    addSkipper = false;
    selectedWatersports = [];
    customExtrasText = '';
    activeBoatType = 'no-license';

    // Auto-resolve name from ID
    if (selectedServiceId && selectedSubOptionId && !selectedSubOptionName) {
      if (selectedServiceId === 'boat-rental') {
        // Can't lookup BoatCard data client-side, leave ID as display
      } else if (selectedServiceId === 'private-tours') {
        // Same
      }
    }

    if (selectedServiceId && selectedSubOptionId) goToStep(3);
    else if (selectedServiceId) goToStep(2);
    else goToStep(1);

    requestAnimationFrame(() => { modal.classList.add('open'); });
  }

  function close() {
    modal.classList.remove('open');
    document.body.style.overflow = '';
    setTimeout(() => { modal.hidden = true; }, 400);
  }

  // ── Event bindings ────────────────────────────────

  closeBtn.addEventListener('click', close);
  backdrop.addEventListener('click', close);

  backBtn.addEventListener('click', () => {
    if (step === 4) goToStep(3);
    else if (step === 3) {
      if (selectedServiceId === 'custom') goToStep(1);
      else goToStep(2);
    } else if (step === 2) goToStep(1);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.hidden && modal.classList.contains('open')) close();
  });

  window.__openBookingModal = open;
})();
</script>
