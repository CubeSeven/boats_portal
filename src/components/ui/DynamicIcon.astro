---
/**
 * DynamicIcon — renders an inline SVG icon by name.
 *
 * Replaces the previous lucide-react based implementation with a local,
 * self-contained map of inline SVG path data. Only the icons actually
 * referenced across the site are included, keeping the bundle tiny and
 * removing the React dependency entirely.
 *
 * Resolution mirrors the old behaviour:
 *   1. If `name` looks like raw SVG path data (starts with "M"), render it directly.
 *   2. Otherwise normalize the name (lowercase, alphanumeric only) and look it up.
 *   3. Fall back to a question-circle icon when no match is found.
 */

interface Props {
  name: string;
  size?: number;
  strokeWidth?: number;
  className?: string;
}

const { name, size = 24, strokeWidth = 2, className } = Astro.props;

// Icon map keyed by normalized name (lowercase, alphanumeric only).
// Each value is the inner SVG markup (paths/circles/rects/etc.) rendered
// inside a 24x24 viewBox with currentColor stroke.
const ICONS: Record<string, string> = {
  // --- Brand / social icons (custom, kept from previous implementation) ---
