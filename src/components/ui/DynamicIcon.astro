---
import * as Icons from 'lucide-react';

interface Props {
  name: string;
  size?: number;
  strokeWidth?: number;
  className?: string;
}

const { name, size = 24, strokeWidth = 2, className } = Astro.props;

// Safety check: ensure name is a string
const isString = typeof name === 'string';
const isPath = isString && name.startsWith('M');

// Helper to find the icon component
// Maps names like "zap" or "Zap" to the Lucide component
// Custom brand icons since Lucide removed them
const BRAND_ICONS: Record<string, any> = {
  facebook: {
    path: '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>',
    viewBox: '0 0 24 24'
  },
  instagram: {
    path: '<rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>',
    viewBox: '0 0 24 24'
  },
  twitter: {
    path: '<path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/>',
    viewBox: '0 0 24 24'
  },
  youtube: {
    path: '<path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 2-2h15a2 2 0 0 1 2 2 24.12 24.12 0 0 1 0 10 2 2 0 0 1-2 2h-15a2 2 0 0 1-2-2Zm10-2 5-3-5-3v6Z"/>',
    viewBox: '0 0 24 24'
  }
};

const getIcon = () => {
  if (!name || typeof name !== 'string') return Icons.HelpCircle;
  if (isPath) return null;
  
  const normalizedName = name.toLowerCase().replace(/[^a-z0-9]/g, '');
  
  // Check custom brands first
  if (BRAND_ICONS[normalizedName]) return { isBrand: true, ...BRAND_ICONS[normalizedName] };

  // Try direct match
  if ((Icons as any)[name]) return (Icons as any)[name];
  
  // Try PascalCase conversion (zap -> Zap, message-circle -> MessageCircle)
  const pascalName = name
    .split('-')
    .map(part => part.charAt(0).toUpperCase() + part.slice(1).toLowerCase())
    .join('');
  
  if ((Icons as any)[pascalName]) return (Icons as any)[pascalName];
  
  // Try a more aggressive search (e.g. palmtree -> PalmTree)
  const allIcons = Icons as any;
  for (const key in allIcons) {
    if (key.toLowerCase() === normalizedName) return allIcons[key];
  }
  
  return Icons.HelpCircle;
};

const IconData = getIcon();
const isBrand = (IconData as any)?.isBrand;
const LucideIcon = !isBrand ? IconData : null;
---

{isPath ? (
  <svg 
    width={size} 
    height={size} 
    viewBox="0 0 24 24" 
    fill="none" 
    stroke="currentColor" 
    stroke-width={strokeWidth} 
    stroke-linecap="round" 
    stroke-linejoin="round" 
    class={className}
    aria-hidden="true"
  >
    <path d={name}/>
  </svg>
) : isBrand ? (
  <svg 
    width={size} 
    height={size} 
    viewBox={IconData.viewBox}
    fill="none" 
    stroke="currentColor" 
    stroke-width={strokeWidth} 
    stroke-linecap="round" 
    stroke-linejoin="round" 
    class={className}
    aria-hidden="true"
    set:html={IconData.path}
  />
) : (
  <LucideIcon size={size} strokeWidth={strokeWidth} className={className} />
)}
