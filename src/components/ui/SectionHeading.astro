---
interface Props {
  label?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center' | 'right';
  titleSize?: 'sm' | 'md' | 'lg';
  dark?: boolean;
}

const {
  label,
  title,
  description,
  align = 'center',
  titleSize = 'lg',
  dark = false,
} = Astro.props;

const alignmentClasses = {
  left: 'items-start text-left',
  center: 'items-center text-center',
  right: 'items-end text-right',
};

const titleSizeClasses = {
  sm: 'text-2xl md:text-3xl',
  md: 'text-3xl md:text-4xl',
  lg: 'text-4xl md:text-5xl lg:text-6xl',
};
---

<div class={`flex flex-col gap-2 mb-12 reveal ${alignmentClasses[align]}`}>
  {label && <span class="section-label">{label}</span>}
  <h2 
    class={`m-0 font-black tracking-tighter leading-[0.9] text-current ${titleSizeClasses[titleSize]}`} 
    set:html={title} 
  />
  {description && (
    <p class={`m-0 text-lg leading-relaxed max-w-2xl mt-4 opacity-60 ${align === 'center' ? 'mx-auto' : ''}`}>
      {description}
    </p>
  )}
</div>
