---
import fs from 'fs';
import path from 'path';

interface Props {
  src: string;
  alt: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  decoding?: 'async' | 'sync' | 'auto';
  fetchpriority?: 'high' | 'low' | 'auto';
  sizes?: string;
}

const {
  src,
  alt,
  class: className,
  loading = 'lazy',
  decoding = 'async',
  fetchpriority,
  sizes,
} = Astro.props;

// Prefix site-root asset paths with the Astro base URL so images resolve on
// GitHub Pages (https://cubeseven.github.io/boats_portal/) and any sub-path deploy.
// Absolute/external URLs (http://, https://, //) are left untouched.
const BASE = import.meta.env.BASE_URL || '/';
function withBase(p: string): string {
  if (!p) return p;
  if (/^(https?:)?\/\//i.test(p)) return p;
  if (p.startsWith(BASE)) return p;
  return (BASE.endsWith('/') ? BASE.slice(0, -1) : BASE) + (p.startsWith('/') ? p : '/' + p);
}

// Derive WebP path from the original src
const ext = path.extname(src);
const webpSrc = src.replace(ext, '.webp');
const webpSmallSrc = src.replace(ext, '-sm.webp');

const resolvedSrc = withBase(src);
const resolvedWebpSrc = withBase(webpSrc);
const resolvedWebpSmallSrc = withBase(webpSmallSrc);

// Check if WebP versions exist in public/
const publicDir = path.join(process.cwd(), 'public');
const webpPath = path.join(publicDir, webpSrc.replace(/^\//, ''));
const webpSmallPath = path.join(publicDir, webpSmallSrc.replace(/^\//, ''));
const hasWebP = fs.existsSync(webpPath);
const hasSmallWebP = fs.existsSync(webpSmallPath);
---

{
  hasWebP ? (
    <picture>
      {hasSmallWebP && (
        <source srcset={encodeURI(resolvedWebpSmallSrc)} media="(max-width: 640px)" type="image/webp" />
      )}
      <source srcset={encodeURI(resolvedWebpSrc)} type="image/webp" />
      <img
        src={encodeURI(resolvedSrc)}
        alt={alt}
        class={className}
        loading={loading}
        decoding={decoding}
        fetchpriority={fetchpriority}
        sizes={sizes}
      />
    </picture>
  ) : (
    <img
      src={encodeURI(resolvedSrc)}
      alt={alt}
      class={className}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
      sizes={sizes}
    />
  )
}
