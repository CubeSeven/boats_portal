---
import Picture from '../ui/Picture.astro';

interface Props {
  title: string;
  description: string;
  href: string;
  price?: string;
  image?: string;
  accent?: 'blue' | 'yellow' | 'green' | 'red' | 'purple' | 'black' | 'muted';
}

const {
  title,
  description,
  href,
  price,
  image,
} = Astro.props;
---

<div class="reveal h-full">
  <a href={href} class="card group h-full">
    <div class="card-content">
      {image && (
        <div class="h-[160px] relative overflow-hidden border-b border-border">
          <Picture
            src={image}
            alt={title}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-[var(--duration-slow)] ease-[var(--ease-premium)] group-hover:scale-105"
            loading="lazy"
            decoding="async"
          />
        </div>
      )}
      <div class="card-body p-8">
        <div class="flex flex-col gap-2">
          <h3 class="text-2xl font-black tracking-tighter m-0 text-current break-words leading-tight">{title}</h3>
          <p class="text-sm opacity-80 font-medium leading-relaxed m-0">{description}</p>
        </div>

        <div class="mt-auto pt-6 border-t border-border flex items-center justify-between">
          {price && <span class="text-sm font-bold text-current">{price}</span>}
          <span class="text-[0.7rem] font-extrabold uppercase tracking-widest text-current opacity-40 group-hover:opacity-100 group-hover:translate-x-1 transition-[opacity,transform] duration-[var(--duration-normal)] ease-[var(--ease-premium)]">
            Explore →
          </span>
        </div>
      </div>
    </div>
  </a>
</div>
