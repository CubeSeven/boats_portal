---
import Picture from '../ui/Picture.astro';

interface Spec {
  label: string;
  value: string;
}

interface Props {
  name: string;
  type: string;
  priceFrom: string | number;
  slug: string;
  specs: Spec[];
  priceHalfDay?: string | number;
  priceFullDay?: string | number;
  features?: string[];
  image?: string;
  imagePlaceholder?: string;
}

const {
  name,
  type,
  priceFrom,
  slug,
  specs = [],
  priceHalfDay,
  priceFullDay,
  features = [],
  image,
} = Astro.props;

// Every boat is either License Required, No License Required, or Skipper Required
const requirementLabels: Record<string, string> = {
  'no-license': 'No License Required',
  'with-license': 'License Required',
  'rib': 'License Required',
  'yacht': 'Skipper Required',
};
const requirement = requirementLabels[type] || 'License Required';
const isNoLicense = type === 'no-license';
const isSkipperRequired = type === 'yacht';

// Clean category label for the card
const typeLabels: Record<string, string> = {
  'no-license': 'Self-Drive',
  'with-license': 'Motorboat',
  'rib': 'RIB',
  'yacht': 'Yacht',
};
const typeLabel = typeLabels[type] || type.replace(/-/g, ' ');
---

<!-- Icon definitions as a reusable symbol set -->
<svg style="display:none" aria-hidden="true">
  <defs>
    <symbol id="ico-flag" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></symbol>
    <symbol id="ico-shield" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></symbol>
    <symbol id="ico-waves" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></symbol>
    <symbol id="ico-bolt" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></symbol>
    <symbol id="ico-umbrella" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.5 2 2 6.5 2 12h20c0-5.5-4.5-10-10-10z"/><line x1="12" y1="12" x2="12" y2="22"/><path d="M8 22a4 4 0 0 0 0-8"/></symbol>
    <symbol id="ico-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></symbol>
    <symbol id="ico-users" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></symbol>
    <symbol id="ico-seat" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 18v-6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v6"/><path d="M3 18h18"/><path d="M7 10V6a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v4"/></symbol>
    <symbol id="ico-captain" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M6 21v-1a6 6 0 0 1 12 0v1"/><path d="M8 8l.5-1.5L10 8M14 8l1.5-1.5L16 8"/></symbol>
    <symbol id="ico-badge" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3 3 4-1-1 4 3 3-3 3 1 4-4-1-3 3-3-3-4 1 1-4-3-3 3-3-1-4 4 1z"/><polyline points="9 12 11 14 15 10"/></symbol>
    <symbol id="ico-home" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12l9-9 9 9"/><path d="M5 10v10h14V10"/><path d="M10 20v-6h4v6"/></symbol>
    <symbol id="ico-star" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></symbol>
    <symbol id="ico-anchor" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="3"/><line x1="12" y1="22" x2="12" y2="8"/><path d="M5 12H2a10 10 0 0 0 20 0h-3"/></symbol>
    <symbol id="ico-leaf" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 4 13c0-4 3-7 7-7s7 3 7 7c0 1-.5 2-1 3"/><path d="M11 20c0-4 2-7 5-9"/><path d="M11 20v-7"/></symbol>
    <symbol id="ico-helm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><line x1="12" y1="3" x2="12" y2="9"/><line x1="12" y1="15" x2="12" y2="21"/><line x1="3" y1="12" x2="9" y2="12"/><line x1="15" y1="12" x2="21" y2="12"/><line x1="5.6" y1="5.6" x2="9.9" y2="9.9"/><line x1="14.1" y1="14.1" x2="18.4" y2="18.4"/><line x1="5.6" y1="18.4" x2="9.9" y2="14.1"/><line x1="14.1" y1="9.9" x2="18.4" y2="5.6"/></symbol>
    <symbol id="ico-wind" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/><path d="M9.6 4.6A2 2 0 1 1 11 8H2"/><path d="M12.6 19.4A2 2 0 1 0 14 16H2"/></symbol>
    <symbol id="ico-box" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></symbol>
    <symbol id="ico-layout" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></symbol>
    <symbol id="ico-compass" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></symbol>
    <symbol id="ico-music" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></symbol>
    <symbol id="ico-calendar" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></symbol>
    <symbol id="ico-ladder" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="16" y2="21"/><line x1="8" y1="8" x2="16" y2="8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="18" x2="16" y2="18"/></symbol>
    <symbol id="ico-ruler" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.3 15.3a1 1 0 0 1 0 1.4l-8.5 8.5a1 1 0 0 1-1.4 0l-11-11a1 1 0 0 1 0-1.4l8.5-8.5a1 1 0 0 1 1.4 0z"/><path d="M7.5 7.5l3 3M10.5 4.5l3 3M4.5 10.5l3 3M13.5 7.5l3 3"/></symbol>
    <symbol id="ico-droplet" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></symbol>
    <symbol id="ico-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></symbol>
  </defs>
</svg>

<div class="reveal h-full">
  <article class="card group h-full">
    <div class="card-content">
      <!-- Image -->
      <div class="card-image-wrap">
        {image ? (
          <Picture
            src={image}
            alt={name}
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-[var(--duration-slow)]"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="absolute inset-0 placeholder-neutral group-hover:scale-105 transition-transform duration-[var(--duration-slow)]"></div>
        )}

        {!image && (
          <div class="absolute inset-0 flex items-center justify-center opacity-10">
            <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5"><path d="M22 10a6 6 0 0 1-5 10H7a6 6 0 0 1-5-10 10.3 10.3 0 0 1 20 0z"/></svg>
          </div>
        )}

        <!-- License / skip[er badge -->
        <div class="absolute top-4 right-4 z-20">
          <span class="badge-license">
            {requirement}
          </span>
        </div>
      </div>

      <!-- Content -->
      <div class="flex flex-col flex-1 p-5">
        <!-- Header: name -->
        <header class="card-header">
          <div class="min-w-0">
            <span class="boat-type-label">{typeLabel}</span>
            <h3 class="boat-name" title={name}>{name}</h3>
          </div>
        </header>

        <!-- Specs chips -->
        <div class="specs-row">
          {specs.map((spec) => {
            const normalized = spec.label.toLowerCase();
            let icon = 'ruler';
            if (normalized.includes('length')) icon = 'ruler';
            else if (normalized.includes('capacity') || normalized.includes('pers')) icon = 'users';
            else if (normalized.includes('engine') || normalized.includes('hp') || normalized.includes('power')) icon = 'bolt';
            return (
              <div class="spec-chip">
                <svg class="spec-icon" width="14" height="14"><use href={`#ico-${icon}`} /></svg>
                <span class="spec-value">{spec.value}</span>
              </div>
            );
          })}
        </div>

        <!-- Footer: Price & CTA -->
        <div class="card-footer mt-auto">
          <div class="price-block">
            <span class="price-label">From</span>
            <span class="price-value">
              <span class="price-currency">€</span>{priceFrom}{priceFullDay && <span> / Full Day</span>}
            </span>
          </div>

          <a href={`/fleet/${slug}/`} class="btn-primary-pill group">
            <span>Details</span>
            <svg class="btn-arrow group-hover:translate-x-0.5 transition-transform" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </div>
  </article>
</div>

<style>
  @reference "../../styles/global.css";

  /* === Card === */
  .card {
    @apply rounded-[var(--radius-2xl)] bg-card border border-border/40 overflow-hidden transition-all duration-300 shadow-[0_8px_30px_rgba(0,0,0,0.06)] hover:shadow-[0_20px_50px_rgba(0,0,0,0.12)] hover:-translate-y-1.5;
  }

  .card-content {
    @apply flex flex-col h-full;
  }

  /* === Image wrapper === */
  .card-image-wrap {
    @apply relative w-full aspect-[4/3] overflow-hidden bg-muted rounded-t-[var(--radius-2xl)];
  }

  /* === Badge === */
  .badge-license {
    @apply inline-flex items-center gap-1.5 bg-white/15 backdrop-blur-md text-white text-[0.625rem] font-bold uppercase tracking-[0.12em] px-3 py-1.5 rounded-full border border-white/20 shadow-sm;
  }

  .badge-license::before {
    @apply content-[""] w-1.5 h-1.5 rounded-full bg-white/80;
  }

  /* === Header === */
  .card-header {
    @apply flex items-start justify-between gap-4;
  }

  .boat-type-label {
    @apply text-[0.65rem] font-bold tracking-widest text-primary block mb-1;
  }

  .boat-name {
    @apply text-xl font-bold tracking-tight m-0 text-foreground line-clamp-1;
  }

  /* === Price === */
  .price-block {
    @apply flex flex-col items-start gap-0 shrink-0;
  }

  .price-label {
    @apply text-[0.65rem] font-bold uppercase tracking-[0.1em] opacity-40;
  }

  .price-value {
    @apply text-lg font-bold tracking-tight leading-none opacity-90;
  }

  .price-currency {
    @apply text-sm font-bold opacity-60 mr-0.5;
  }

  .price-secondary {
    @apply text-[0.7rem] font-medium text-foreground/40 whitespace-nowrap mt-0.5;
  }

  .card-footer {
    @apply flex items-center justify-between mt-auto pt-4 border-t border-border/10;
  }

  /* === Specs Row === */
  .specs-row {
    @apply flex flex-wrap gap-2 my-4;
  }

  .spec-chip {
    @apply inline-flex items-center gap-1.5 bg-muted/70 hover:bg-muted transition-colors rounded-md px-2.5 py-1.5;
  }

  .spec-icon {
    @apply opacity-50 flex-shrink-0;
  }

  .spec-value {
    @apply text-xs font-bold tracking-tight leading-none;
  }

  /* === Button === */
  .btn-primary-pill {
    @apply bg-foreground text-background border border-foreground py-2.5 px-8 rounded-full text-[0.75rem] font-bold tracking-[0.1em] flex items-center justify-center transition-all duration-300;
  }

  .btn-primary-pill:hover {
    @apply bg-transparent text-foreground border-foreground/30 shadow-lg;
  }

  .btn-arrow {
    @apply ml-1.5;
  }
</style>
