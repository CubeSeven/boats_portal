---
interface Props {
  quote: string;
  author: string;
  location?: string;
  rating?: number;
  service?: string;
}

const {
  quote,
  author,
  location,
  rating = 5,
  service,
} = Astro.props;
---

<div class="reveal h-full">
  <div class="card group h-full">
    <div class="card-content">
      <div class="card-body p-8 flex flex-col h-full">
        <div class="flex gap-1 mb-6">
          {Array.from({ length: 5 }).map((_, i) => (
            <svg 
              width="16" 
              height="16" 
              viewBox="0 0 24 24" 
              fill={i < rating ? "currentColor" : "none"} 
              stroke="currentColor" 
              stroke-width="2" 
              class={i < rating ? "text-current" : "text-current opacity-20"}
              aria-hidden="true"
            >
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
          ))}
        </div>

        <blockquote class="m-0 flex-1">
          <p class="text-lg font-medium leading-relaxed italic text-current m-0">
            "{quote}"
          </p>
        </blockquote>

        <div class="mt-8 pt-6 border-t border-border/50 flex flex-col gap-1">
          <cite class="not-italic block text-base font-black tracking-tight text-current">
            {author}
          </cite>
          <div class="flex items-center gap-2 text-[0.7rem] font-bold opacity-60 uppercase tracking-widest">
            {location && <span>{location}</span>}
            {service && (
              <>
                <span>•</span>
                <span>{service}</span>
              </>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
