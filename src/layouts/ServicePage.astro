---
import Layout from './Layout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import Breadcrumbs from '../components/ui/Breadcrumbs.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
import BookingWidget from '../components/sections/BookingWidget.astro';
import RelatedContent from '../components/sections/RelatedContent.astro';
import { getSiteSettings } from '../lib/collections';

const site = await getSiteSettings();
const phoneClean = site?.phone?.replace(/ /g, '') || '';

interface FaqItem { question: string; answer: string; }

interface Props {
  [key: string]: any;
  title: string;
  seoTitle?: string;
  description: string;
  heroTitle: string;
  heroSubtitle?: string;
  heroGradient?: string;
  faqs?: FaqItem[];
  ctaTitle?: string;
  ctaSubtitle?: string;
  showBookingWidget?: boolean;
  canonicalUrl?: string;
  category?: string;
  id?: string;
  backgroundImage?: string;
}

const {
  title,
  seoTitle,
  description,
  heroTitle,
  heroSubtitle,
  heroGradient = 'neutral',
  faqs = [],
  ctaTitle = 'Ready to Book?',
  ctaSubtitle = 'Contact us for a free quote. We reply within 2 hours.',
  showBookingWidget = true,
  canonicalUrl,
  category,
  id,
  backgroundImage = '/images/stock/s17tock-images.webp',
} = Astro.props;
---

<Layout
  title={seoTitle ?? title}
  description={description}
  canonicalUrl={canonicalUrl}
>
  <HeroSection
    title={heroTitle}
    subtitle={heroSubtitle}
    ctaText="Request Quote"
    ctaHref="/contact/"
    ctaSecondText="View Fleet"
    ctaSecondHref="/fleet/"
    gradient={heroGradient as any}
    size="medium"
    showScrollHint={false}
    backgroundImage={backgroundImage}
  />

  <Breadcrumbs />

  <div class="service-page-layout container">
    <main class="service-page-main">
      <slot />

      {faqs.length > 0 && (
        <section class="service-faqs">
          <h2>Frequently Asked Questions</h2>
          <FaqAccordion items={faqs} />
        </section>
      )}
    </main>

    {showBookingWidget && (
      <aside class="service-page-sidebar">
        <div class="sidebar-sticky">
          <BookingWidget 
            initialService={category === 'watersports' ? 'watersports' : (category === 'boat-rental' ? 'boat-rental' : '')} 
            initialSubId={category === 'watersports' ? id : ''} 
          />
        </div>
      </aside>
    )}
  </div>

  <RelatedContent 
    collection="activities" 
    currentId={id} 
    category={category}
    title="Other Services & Activities"
    subtitle="From transfer transfers to thrilling watersports — explore more sea experiences."
  />

  <CtaBanner
    title={ctaTitle}
    subtitle={ctaSubtitle}
    buttonText="Book Now"
    buttonHref="/contact/"
    secondButtonText="Call Us"
    secondButtonHref={phoneClean ? `tel:${phoneClean}` : 'tel:+30XXXXXXXXXX'}
    variant="dark"
    backgroundImage="/images/stock/s17tock-images.webp"
  />
</Layout>

<style>
  .service-page-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding-top: 3rem;
    padding-bottom: 2rem;
  }

  @media (min-width: 1024px) {
    .service-page-layout {
      grid-template-columns: 1fr 340px;
      align-items: start;
    }
  }

  .service-page-main {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    min-width: 0;
  }

  .service-page-main :global(h2) {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    color: var(--foreground);
    margin: 0 0 1rem;
  }

  .service-page-main :global(h3) {
    font-size: 1.2rem;
    color: var(--foreground);
    margin: 0 0 0.75rem;
  }

  .service-page-main :global(p) {
    color: var(--muted-foreground);
    line-height: 1.75;
    margin: 0 0 1rem;
  }

  .service-page-main :global(ul), .service-page-main :global(ol) {
    padding-left: 1.5rem;
    color: var(--muted-foreground);
    line-height: 2;
  }

  .service-faqs {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sidebar-sticky {
    position: sticky;
    top: 100px;
  }
</style>
