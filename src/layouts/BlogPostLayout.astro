---
import Layout from './Layout.astro';
import Breadcrumbs from '../components/ui/Breadcrumbs.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
import RelatedContent from '../components/sections/RelatedContent.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  readTime: number;
  category: string;
  imagePlaceholder: string;
  image?: string;
  id?: string;
}

const { title, description, pubDate, readTime, category, imagePlaceholder, image, id } = Astro.props;
---

<Layout title={`${title} | Skiathos Boats Blog`} description={description}>
  <div class="blog-post-header" style={image ? `background-image: url('${image}'); background-size: cover; background-position: center;` : `background: var(--${imagePlaceholder})`}>
    <div class="container header-content">
      <span class="category-badge">{category}</span>
      <h1>{title}</h1>
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
        <span>•</span>
        <span>{readTime} min read</span>
      </div>
    </div>
  </div>

  <Breadcrumbs />

  <article class="blog-post container-narrow">
    <div class="content reveal">
      <slot />
    </div>
  </article>

  <RelatedContent 
    collection="blog" 
    currentId={id} 
    category={category}
    title="More from the Blog"
    subtitle="Read more guides and tips about exploring Skiathos by sea."
  />

  <section class="section">
    <div class="container">
      <CtaBanner
        title="Inspired for a Sea Adventure?"
        subtitle="Book your private boat or tour today and experience Skiathos for yourself."
        buttonText="Get a Quote"
        buttonHref="/contact/"
        variant="dark"
      />
    </div>
  </section>
</Layout>

<style>
  .blog-post-header {
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: white;
    padding: 6rem 0;
    position: relative;
    overflow: hidden;
  }

  /* Overlay gradient to ensure text readability */
  .blog-post-header::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.7) 100%);
  }

  .header-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .category-badge {
    background: var(--foreground);
    padding: 0.35rem 1rem;
    border-radius: var(--radius-full);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .blog-post-header h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin: 0;
  }

  .post-meta {
    font-size: 1rem;
    font-weight: 500;
    opacity: 0.9;
    display: flex;
    gap: 0.75rem;
  }

  .blog-post {
    padding: 4rem 0;
  }

  .container-narrow {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .content :global(h2) {
    font-size: 2rem;
    color: var(--foreground);
    margin: 3rem 0 1.5rem;
  }

  .content :global(h3) {
    font-size: 1.5rem;
    color: var(--foreground);
    margin: 2.5rem 0 1rem;
  }

  .content :global(p) {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--foreground);
    margin-bottom: 2rem;
  }

  .content :global(ul), .content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 2rem;
  }

  .content :global(li) {
    font-size: 1.125rem;
    line-height: 1.8;
    margin-bottom: 0.75rem;
  }

  .content :global(img) {
    border-radius: var(--radius-xl);
    margin: 2rem 0;
    width: 100%;
  }

  .content :global(blockquote) {
    border-left: 4px solid var(--foreground);
    padding-left: 1.5rem;
    font-style: italic;
    color: var(--muted-foreground);
    margin: 3rem 0;
  }

  .content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 3rem 0;
  }

  .content :global(th), .content :global(td) {
    border: 1px solid var(--border);
    padding: 0.75rem 1rem;
    text-align: left;
  }

  .content :global(th) {
    background: var(--muted);
    font-weight: 700;
  }
</style>
